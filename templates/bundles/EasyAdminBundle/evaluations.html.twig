{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Evaluations — {{ year }}{% endblock %}

{% block main %}

<p class="mb-4">
    For the full interactive report, see
    <a href="{{ path('eval_report', {'year': year}) }}">Evaluations Report</a>
    in the main app (requires DOF role).
</p>

<div class="table-responsive mb-5">
    <h3>Ambassador Evaluations <small class="text-muted" style="font-size:14px;">{{ ambassador_evaluations|length }} submitted</small></h3>
    {% if ambassador_evaluations is empty %}
        <p class="text-muted">No submitted ambassador evaluations for {{ year }}.</p>
    {% else %}
    <table class="table table-sm table-striped">
        <thead><tr>
            <th>Ambassador</th><th>Group</th><th>Recommend</th>
            <th>Engaged</th><th>Service</th><th>Submitted By</th>
            <th>Strengths</th><th>Challenges</th><th>Comments</th>
        </tr></thead>
        <tbody>
            {% for eval in ambassador_evaluations %}
            <tr>
                <td><a href="{{ ea_url().setController('App\\Controller\\Admin\\AmbassadorCrudController').setAction('detail').setEntityId(eval.ambassador.id) }}">{{ eval.ambassador.fullName }}</a></td>
                <td>{{ eval.ambassador.letterGroup ? eval.ambassador.letterGroup.letter : '—' }}</td>
                <td>{% if eval.evalRecommendation == '1' %}Yes{% elseif eval.evalRecommendation == '0' %}No{% else %}—{% endif %}</td>
                <td>{{ eval.evalEngaged ?: '—' }}</td>
                <td>{{ eval.evalService ?: '—' }}</td>
                <td>{{ eval.submittedBy ? eval.submittedBy.fullName : '—' }}</td>
                <td style="font-size:12px; max-width:200px;">{{ eval.evalPros ?: '' }}</td>
                <td style="font-size:12px; max-width:200px;">{{ eval.evalCons ?: '' }}</td>
                <td style="font-size:12px; max-width:180px;">{{ eval.evalComments ?: '' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

<div class="table-responsive mb-5">
    <h3>Staff Evaluations <small class="text-muted" style="font-size:14px;">{{ user_evaluations|length }} submitted</small></h3>
    {% if user_evaluations is empty %}
        <p class="text-muted">No submitted staff evaluations for {{ year }}.</p>
    {% else %}
    <table class="table table-sm table-striped" style="font-size:12px;">
        <thead><tr>
            <th>Subject</th><th>Evaluator</th>
            <th>Disc.</th><th>Enthus.</th><th>Organ.</th><th>Equally</th>
            <th>Resp.</th><th>Atten.</th><th>Incl.</th><th>Prof.</th><th>Punct.</th>
            <th>Strengths</th><th>Challenges</th><th>Why Not Return</th>
        </tr></thead>
        <tbody>
            {% for eval in user_evaluations %}
            <tr>
                <td><a href="{{ ea_url().setController('App\\Controller\\Admin\\StaffAssignmentCrudController').setAction('detail').setEntityId(eval.subject.id) }}">{{ eval.subject.fullName }}</a></td>
                <td>{{ eval.evaluator ? eval.evaluator.fullName : '—' }}</td>
                <td>{{ eval.evalDiscussions ?: '—' }}</td>
                <td>{{ eval.evalEnthusiastic ?: '—' }}</td>
                <td>{{ eval.evalOrganized ?: '—' }}</td>
                <td>{{ eval.evalEqually ?: '—' }}</td>
                <td>{{ eval.evalResponsible ?: '—' }}</td>
                <td>{{ eval.evalAttentive ?: '—' }}</td>
                <td>{{ eval.evalInclude ?: '—' }}</td>
                <td>{{ eval.evalProfessional ?: '—' }}</td>
                <td>{{ eval.evalPunctual ?: '—' }}</td>
                <td style="max-width:180px;">{{ eval.evalPros ?: '' }}</td>
                <td style="max-width:180px;">{{ eval.evalCons ?: '' }}</td>
                <td style="max-width:180px;">{{ eval.evalWhynot ?: '' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>

{% endblock %}
