{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
    <div class="form-page">
        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="error" role="alert">{{ flash_error }}</div>
        {% endfor %}
        
        <h1>Reset your password</h1>
    
        {{ form_start(requestForm) }}
            <div class="mb-3">
                <label for="email" class="form-label">{{ form_label(requestForm.email) }}</label>
                {{ form_widget(requestForm.email) }}
                <div class="form-text">Enter your email address and we will send you a link to reset your password.</div>
            </div>
            <button class="mb-3 form-control btn btn-primary">Send password reset email</button>
        {{ form_end(requestForm) }}
    </div>
{% endblock %}



