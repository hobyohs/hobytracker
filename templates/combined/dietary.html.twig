{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}
{% block maintag %}<main class="wide">{% endblock %}
{% block body %}
<div class="ht-page-header"><h1>Dietary Info</h1></div>
<div class="ht-dt-card ht-responsive-table">
    <table class="table" id="dietary-table">
        <thead><tr>
            <th class="ht-avatar-col no-export"></th>
            <th>First Name</th><th class="ht-mobile-hide">Last Name</th><th class="ht-mobile-hide">Group</th>
            <th>Diet Restrictions</th><th>Diet Info</th>
            <th class="no-export ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for person in people %}
                <tr data-href="{{ path(person.showpath, { 'id': person.id }) }}">
                    <td class="ht-avatar-col no-export">{{ avatar.render(person, 32) }}</td>
                    <td data-label="First" class="ht-name-td">
                        <span class="ht-name-desktop">{{ person.firstName }}</span>
                        <span class="ht-name-mobile-header">
                            {{ avatar.render(person, 36) }}
                            <span class="ht-card-name">{{ person.firstName }} {{ person.lastName }}</span>
                            {% if person.group == "Staff" %}<span class="ht-group-badge ht-card-name-badge" style="background:#eef1f4;color:#666">Staff</span>
                            {% elseif person.group is not empty %}<span class="ht-group-badge ht-group-{{ person.group.color }} ht-card-name-badge">{{ person.group.letter }}</span>{% endif %}
                        </span>
                    </td>
                    <td data-label="Last" class="ht-mobile-hide">{{ person.lastName }}</td>
                    <td data-label="Group" class="center ht-mobile-hide">{% if person.group == "Staff" %}Staff{% elseif person.group is not empty %}<span class="ht-group-badge ht-group-{{ person.group.color }}">{{ person.group.letter }}</span>{% endif %}</td>
                    <td data-label="Restrictions">{{ person.dietRestrictions }}</td>
                    <td data-label="Info">{{ person.dietInfo }}</td>
                    <td class="no-export ht-chevron-col"><a href="{{ path(person.showpath, { 'id': person.id }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
