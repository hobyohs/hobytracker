{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}

{% block maintag %}<main class="show user">{% endblock %}

{% block body %}

<a href="{{ path('app_user_show', {'id': app.user.id}) }}" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> My Profile
</a>

{%- set groupColor = user.letterGroup ? user.letterGroup.color : '' -%}

{# ── Header ─────────────────────────────────────────────── #}
<div class="ht-show-header">
    {{ avatar.render(user, 88) }}

    <div class="ht-show-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</div>
    <div class="ht-show-subtitle">{{ user.position }}</div>

    {% if user.letterGroup %}
        <div class="ht-show-badges">
            <a href="{{ path('app_letter_group_show', { 'letter': user.letterGroup.letter }) }}"
               class="ht-group-badge ht-group-badge-lg ht-group-{{ groupColor }}"
               style="text-decoration:none;">
                Group {{ user.letterGroup.letter }}
            </a>
        </div>
    {% endif %}
</div>

<div class="ht-show-body">

{# ── Check In ────────────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Check In</div>
    <div class="ht-section-card">
        <div class="ht-section-row">
            <span class="ht-section-key">Assignment</span>
            <span class="ht-section-val{% if not user.assignmentCheckIn %} ht-empty{% endif %}">
                {{ user.assignmentCheckIn ?: 'Not assigned' }}
            </span>
        </div>
        {% if user.assignmentCheckInNotes %}
            <div class="ht-section-row-block">
                <div class="ht-section-key">Notes</div>
                <div class="ht-section-val">{{ user.assignmentCheckInNotes|nl2br }}</div>
            </div>
        {% endif %}
    </div>
</div>

{# ── Closing Ceremony ────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Closing Ceremony</div>
    <div class="ht-section-card">
        <div class="ht-section-row">
            <span class="ht-section-key">Assignment</span>
            <span class="ht-section-val{% if not user.assignmentClosingCeremonies %} ht-empty{% endif %}">
                {{ user.assignmentClosingCeremonies ?: 'Not assigned' }}
            </span>
        </div>
        {% if user.assignmentClosingCeremoniesNotes %}
            <div class="ht-section-row-block">
                <div class="ht-section-key">Notes</div>
                <div class="ht-section-val">{{ user.assignmentClosingCeremoniesNotes|nl2br }}</div>
            </div>
        {% endif %}
    </div>
</div>

{# ── Check Out ───────────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Check Out</div>
    <div class="ht-section-card">
        <div class="ht-section-row">
            <span class="ht-section-key">Assignment</span>
            <span class="ht-section-val{% if not user.assignmentCheckOut %} ht-empty{% endif %}">
                {{ user.assignmentCheckOut ?: 'Not assigned' }}
            </span>
        </div>
        {% if user.assignmentCheckOutNotes %}
            <div class="ht-section-row-block">
                <div class="ht-section-key">Notes</div>
                <div class="ht-section-val">{{ user.assignmentCheckOutNotes|nl2br }}</div>
            </div>
        {% endif %}
    </div>
</div>

</div>{# end ht-show-body #}

{% endblock %}
