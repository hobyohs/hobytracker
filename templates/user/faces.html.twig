{% extends 'base.html.twig' %}

{% block maintag %}<main class="wide">{% endblock %}

{% block body %}

{# Build sorted list of letter groups present in this year's staff #}
{% set groups_map = {} %}
{% for user in users %}
    {% if user.letterGroup %}
        {% set groups_map = groups_map|merge({ (user.letterGroup.letter): user.letterGroup }) %}
    {% endif %}
{% endfor %}
{% set sorted_letters = groups_map|keys|sort %}

<div class="ht-page-header">
    <h1>Staff Faces</h1>
    <span class="ht-page-count">{{ users|length }}</span>
</div>

<div class="ht-list-controls">
    <input type="text" id="facesStaffSearch" class="ht-search-input" placeholder="Search name or position…" autocomplete="off" autocorrect="off" spellcheck="false">
    <div class="ht-filter-pills">
        <span class="ht-pill faces-staff-pill active" data-filter="all">All</span>
        {% for letter in sorted_letters %}
            <span class="ht-pill faces-staff-pill" data-filter="{{ letter }}">{{ letter }}</span>
        {% endfor %}
    </div>
</div>

<div class="ht-faces-grid" id="facesStaffGrid">
    {% for user in users %}
        {%- set initials = user.consolidatedFirstName[0:1]|upper ~ user.lastName[0:1]|upper -%}
        {%- set groupLetter = user.letterGroup ? user.letterGroup.letter : '' -%}
        {%- set groupColor  = user.letterGroup ? user.letterGroup.color  : '' -%}
        <a href="{{ path('app_user_show', { 'id': user.userId }) }}"
           class="ht-face-card"
           data-name="{{ (user.consolidatedFirstName ~ ' ' ~ user.lastName)|lower }}"
           data-sub="{{ user.position|lower }}"
           data-group="{{ groupLetter }}">
            {% if user.photo %}
                <img src="{{ user.photo }}" alt="{{ user.consolidatedFirstName }} {{ user.lastName }}" class="ht-face-photo" loading="lazy">
            {% else %}
                <div class="ht-face-photo-placeholder">{{ initials }}</div>
            {% endif %}
            <div class="ht-face-body">
                <div class="ht-face-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</div>
                <div class="ht-face-meta">{{ user.position }}</div>
                {% if user.letterGroup %}
                    <span class="ht-face-group ht-group-{{ groupColor }}">Group {{ groupLetter }}</span>
                {% endif %}
            </div>
        </a>
    {% else %}
        <div class="ht-no-results" style="display:block; grid-column:1/-1;">No staff found.</div>
    {% endfor %}
    <div class="ht-no-results" style="grid-column:1/-1;">No results match your search.</div>
</div>

{% endblock %}
