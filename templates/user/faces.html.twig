{% extends 'base.html.twig' %}

{% block body %}
	<h1>Our Staff</h1>

	<div class="container faces">
		<div class="row">
			{% for user in users %}
				
					<div class="col-sm-6 col-md-4 col-lg-3 mb-4">
						
						<div class="card border-0 shadow">
							<img src="{{ user.photo ?? asset('assets/images/headshot-placeholder.png') }}" class="card-img-top" alt="{{ user.fullName }}"">
							<div class="card-body text-center">
								<a href="{{ path('app_user_show', { 'id': user.id }) }}" class="stretched-link">
									<h5 class="card-title mb-0">{{ user.fullName }}</h5>
									<div class="card-text">
										{{ user.position }}
										{% if not user.letterGroup is empty %}
											<br>
											Group {{ user.letterGroup.letter }}
										{% endif %}</span>
									</div>
									</a>
							</div>
						</div>
					</div>
				
			{% endfor %}
		</div>
	
	</div>

	
{% endblock %}
