{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}
{% block maintag %}<main class="wide">{% endblock %}

{% block body %}

<a href="{{ path('homepage') }}" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> Home
</a>

<div class="ht-page-header">
    <h1>Duty Assignments</h1>
</div>

{# ── Tab bar ─────────────────────────────────────────────── #}
<div class="ht-tab-bar">
    <div class="ht-tab-bar-inner">
        <a href="{{ path('app_user_duty_assignments', {'tab': 'checkin'}) }}"
           class="ht-tab {{ tab == 'checkin' ? 'is-active' : '' }}">Check-In</a>
        <a href="{{ path('app_user_duty_assignments', {'tab': 'checkout'}) }}"
           class="ht-tab {{ tab == 'checkout' ? 'is-active' : '' }}">Check-Out</a>
        <a href="{{ path('app_user_duty_assignments', {'tab': 'cc'}) }}"
           class="ht-tab {{ tab == 'cc' ? 'is-active' : '' }}">Closing Ceremony</a>
        <a href="{{ path('app_user_duty_assignments', {'tab': 'bedchecks'}) }}"
           class="ht-tab {{ tab == 'bedchecks' ? 'is-active' : '' }}">Bed Checks</a>
    </div>
</div>

{# ── Check-In Assignments ─────────────────────────────────── #}
{% if tab == 'checkin' %}
<div class="ht-dt-card ht-responsive-table">
    <table class="table" id="duty-table">
        <thead><tr>
            <th class="ht-avatar-col no-export"></th>
            <th>First Name</th><th class="ht-mobile-hide">Last Name</th><th class="ht-mobile-hide">Position</th>
            <th>Assignment</th><th>Notes</th>
            <th class="no-export ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for user in users %}
                {% if user.assignmentCheckIn is not null or user.assignmentCheckInNotes is not null %}
                    <tr data-href="{{ path('app_user_show', { 'id': user.userId }) }}">
                        <td class="ht-avatar-col no-export">{{ avatar.render(user, 32) }}</td>
                        <td data-label="First" class="ht-name-td">
                            <span class="ht-name-desktop">{{ user.consolidatedFirstName }}</span>
                            <span class="ht-name-mobile-header">
                                {{ avatar.render(user, 36) }}
                                <span class="ht-name-mobile-text">
                                    <span class="ht-card-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</span>
                                    {% if user.position %}<span class="ht-card-sub">{{ user.position }}</span>{% endif %}
                                </span>
                            </span>
                        </td>
                        <td data-label="Last" class="ht-mobile-hide">{{ user.lastName }}</td>
                        <td data-label="Position" class="ht-mobile-hide">{{ user.position }}</td>
                        <td data-label="Assignment">{{ user.assignmentCheckIn }}</td>
                        <td data-label="Notes" class="{{ not user.assignmentCheckInNotes ? 'ht-mobile-hide' : '' }}">{{ user.assignmentCheckInNotes }}</td>
                        <td class="no-export ht-chevron-col"><a href="{{ path('app_user_show', { 'id': user.userId }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                    </tr>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>

{# ── Check-Out Assignments ────────────────────────────────── #}
{% elseif tab == 'checkout' %}
<div class="ht-dt-card ht-responsive-table">
    <table class="table" id="duty-table">
        <thead><tr>
            <th class="ht-avatar-col no-export"></th>
            <th>First Name</th><th class="ht-mobile-hide">Last Name</th><th class="ht-mobile-hide">Position</th>
            <th>Assignment</th><th>Notes</th>
            <th class="no-export ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for user in users %}
                {% if user.assignmentCheckOut is not null or user.assignmentCheckOutNotes is not null %}
                    <tr data-href="{{ path('app_user_show', { 'id': user.userId }) }}">
                        <td class="ht-avatar-col no-export">{{ avatar.render(user, 32) }}</td>
                        <td data-label="First" class="ht-name-td">
                            <span class="ht-name-desktop">{{ user.consolidatedFirstName }}</span>
                            <span class="ht-name-mobile-header">
                                {{ avatar.render(user, 36) }}
                                <span class="ht-name-mobile-text">
                                    <span class="ht-card-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</span>
                                    {% if user.position %}<span class="ht-card-sub">{{ user.position }}</span>{% endif %}
                                </span>
                            </span>
                        </td>
                        <td data-label="Last" class="ht-mobile-hide">{{ user.lastName }}</td>
                        <td data-label="Position" class="ht-mobile-hide">{{ user.position }}</td>
                        <td data-label="Assignment">{{ user.assignmentCheckOut }}</td>
                        <td data-label="Notes" class="{{ not user.assignmentCheckOutNotes ? 'ht-mobile-hide' : '' }}">{{ user.assignmentCheckOutNotes }}</td>
                        <td class="no-export ht-chevron-col"><a href="{{ path('app_user_show', { 'id': user.userId }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                    </tr>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>

{# ── Closing Ceremony Assignments ─────────────────────────── #}
{% elseif tab == 'cc' %}
<div class="ht-dt-card ht-responsive-table">
    <table class="table" id="duty-table">
        <thead><tr>
            <th class="ht-avatar-col no-export"></th>
            <th>First Name</th><th class="ht-mobile-hide">Last Name</th><th class="ht-mobile-hide">Position</th>
            <th>Assignment</th><th>Notes</th>
            <th class="no-export ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for user in users %}
                {% if user.assignmentClosingCeremonies is not null or user.assignmentClosingCeremoniesNotes is not null %}
                    <tr data-href="{{ path('app_user_show', { 'id': user.userId }) }}">
                        <td class="ht-avatar-col no-export">{{ avatar.render(user, 32) }}</td>
                        <td data-label="First" class="ht-name-td">
                            <span class="ht-name-desktop">{{ user.consolidatedFirstName }}</span>
                            <span class="ht-name-mobile-header">
                                {{ avatar.render(user, 36) }}
                                <span class="ht-name-mobile-text">
                                    <span class="ht-card-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</span>
                                    {% if user.position %}<span class="ht-card-sub">{{ user.position }}</span>{% endif %}
                                </span>
                            </span>
                        </td>
                        <td data-label="Last" class="ht-mobile-hide">{{ user.lastName }}</td>
                        <td data-label="Position" class="ht-mobile-hide">{{ user.position }}</td>
                        <td data-label="Assignment">{{ user.assignmentClosingCeremonies }}</td>
                        <td data-label="Notes" class="{{ not user.assignmentClosingCeremoniesNotes ? 'ht-mobile-hide' : '' }}">{{ user.assignmentClosingCeremoniesNotes }}</td>
                        <td class="no-export ht-chevron-col"><a href="{{ path('app_user_show', { 'id': user.userId }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                    </tr>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

{# ── Bed Checks Assignments ───────────────────────────────── #}
{% if tab == 'bedchecks' %}
<div class="ht-dt-card ht-responsive-table">
    {% if bcByStaff is empty %}
        <div style="padding: 24px; text-align: center; color: var(--ht-sub);">
            No bed check assignments yet.
            <a href="{{ path('bedcheck_assignments') }}">Manage assignments</a>
        </div>
    {% else %}
        <table class="table" id="duty-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Thursday</th>
                    <th>Friday</th>
                    <th>Saturday</th>
                </tr>
            </thead>
            <tbody>
            {% for entry in bcByStaff %}
                <tr>
                    <td data-label="Name">
                        {{ entry.staff.consolidatedFirstName }} {{ entry.staff.lastName }}
                    </td>
                    {% for night in ['Thursday', 'Friday', 'Saturday'] %}
                        <td data-label="{{ night }}">
                            {% if entry.nights[night] is not empty %}
                                {{ entry.nights[night]|join(', ') }}
                            {% else %}
                                <span style="color: var(--ht-sub);">—</span>
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
<div style="margin: 12px 16px;">
    <a href="{{ path('bedcheck_assignments') }}" class="ht-page-header-action">
        <i class="fa fa-users-gear"></i> Manage Assignments
    </a>
</div>
{% endif %}

{% endblock %}
