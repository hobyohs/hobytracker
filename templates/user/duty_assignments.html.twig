{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}
{% block maintag %}<main class="wide">{% endblock %}

{# ── Editable assignment table macro ────────────────────────── #}
{% macro editable_table(users, assignmentField, notesField, assignmentGetter, notesGetter) %}
{% import 'partials/_avatar.html.twig' as avatar %}
<div class="ht-da-filter">
    <input type="text" class="ht-da-filter-input" placeholder="Search staff…" autocomplete="off">
</div>
<div class="ht-dt-card ht-responsive-table">
    <table class="table ht-da-table">
        <thead><tr>
            <th class="ht-avatar-col"></th>
            <th>First Name</th>
            <th class="ht-mobile-hide">Last Name</th>
            <th class="ht-mobile-hide">Position</th>
            <th>Assignment</th>
            <th>Notes</th>
            <th class="ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for user in users %}
                <tr data-search="{{ user.consolidatedFirstName|lower }} {{ user.lastName|lower }} {{ user.position|lower }}">
                    <td class="ht-avatar-col">{{ avatar.render(user, 32) }}</td>
                    <td data-label="First" class="ht-name-td">
                        <span class="ht-name-desktop">{{ user.consolidatedFirstName }}</span>
                        <span class="ht-name-mobile-header">
                            {{ avatar.render(user, 36) }}
                            <span class="ht-name-mobile-text">
                                <span class="ht-card-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</span>
                                {% if user.position %}<span class="ht-card-sub">{{ user.position }}</span>{% endif %}
                            </span>
                        </span>
                    </td>
                    <td data-label="Last" class="ht-mobile-hide">{{ user.lastName }}</td>
                    <td data-label="Position" class="ht-mobile-hide">{{ user.position }}</td>
                    <td data-label="Assignment"
                        class="ht-da-editable ht-da-assignment"
                        data-staff-id="{{ user.id }}"
                        data-field="{{ assignmentField }}">{{ attribute(user, assignmentGetter) }}</td>
                    <td data-label="Notes"
                        class="ht-da-editable ht-da-notes"
                        data-staff-id="{{ user.id }}"
                        data-field="{{ notesField }}">{{ attribute(user, notesGetter) }}</td>
                    <td class="ht-chevron-col"><a href="{{ path('app_user_show', { 'id': user.userId }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endmacro %}

{% block body %}

<a href="{{ path('homepage') }}" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> Home
</a>

<div class="ht-page-header">
    <h1>Duty Assignments</h1>
</div>

{# ── Tab bar ─────────────────────────────────────────────── #}
<div class="ht-tab-bar">
    <div class="ht-tab-bar-inner">
        <a href="{{ path('app_user_duty_assignments', {'tab': 'checkin'}) }}"
           class="ht-tab {{ tab == 'checkin' ? 'is-active' : '' }}">Check-In</a>
        <a href="{{ path('app_user_duty_assignments', {'tab': 'checkout'}) }}"
           class="ht-tab {{ tab == 'checkout' ? 'is-active' : '' }}">Check-Out</a>
        <a href="{{ path('app_user_duty_assignments', {'tab': 'cc'}) }}"
           class="ht-tab {{ tab == 'cc' ? 'is-active' : '' }}">Closing Ceremony</a>
        <a href="{{ path('app_user_duty_assignments', {'tab': 'bedchecks'}) }}"
           class="ht-tab {{ tab == 'bedchecks' ? 'is-active' : '' }}">Bed Checks</a>
    </div>
</div>

{# ── Check-In Assignments ─────────────────────────────────── #}
{% if tab == 'checkin' %}
    <p class="ht-da-hint"><i class="fa fa-pencil"></i> Click any Assignment or Notes cell to edit</p>
    {% set assignmentField = 'assignmentCheckIn' %}
    {% set notesField = 'assignmentCheckInNotes' %}
    {% set assignmentGetter = 'assignmentCheckIn' %}
    {% set notesGetter = 'assignmentCheckInNotes' %}
    {{ _self.editable_table(users, assignmentField, notesField, assignmentGetter, notesGetter) }}

{# ── Check-Out Assignments ────────────────────────────────── #}
{% elseif tab == 'checkout' %}
    <p class="ht-da-hint"><i class="fa fa-pencil"></i> Click any Assignment or Notes cell to edit</p>
    {% set assignmentField = 'assignmentCheckOut' %}
    {% set notesField = 'assignmentCheckOutNotes' %}
    {% set assignmentGetter = 'assignmentCheckOut' %}
    {% set notesGetter = 'assignmentCheckOutNotes' %}
    {{ _self.editable_table(users, assignmentField, notesField, assignmentGetter, notesGetter) }}

{# ── Closing Ceremony Assignments ─────────────────────────── #}
{% elseif tab == 'cc' %}
    <p class="ht-da-hint"><i class="fa fa-pencil"></i> Click any Assignment or Notes cell to edit</p>
    {% set assignmentField = 'assignmentClosingCeremonies' %}
    {% set notesField = 'assignmentClosingCeremoniesNotes' %}
    {% set assignmentGetter = 'assignmentClosingCeremonies' %}
    {% set notesGetter = 'assignmentClosingCeremoniesNotes' %}
    {{ _self.editable_table(users, assignmentField, notesField, assignmentGetter, notesGetter) }}

{% endif %}

{# ── Bed Checks Assignments ───────────────────────────────── #}
{% if tab == 'bedchecks' %}

<p class="ht-page-sub" style="margin: 0 16px 16px;">Assign staff to dorm floors for each night. Click <strong>+</strong> to add, <strong>×</strong> to remove.</p>

{% if bcFloors is empty %}
    <div class="ht-section-card" style="margin: 20px 16px; text-align: center; color: var(--ht-sub);">
        No dorm rooms assigned yet.
    </div>
{% else %}

{# ── Desktop grid ────────────────────────────────────────── #}
<div class="ht-bca-grid">
    <table class="ht-bca-table">
        <thead>
            <tr>
                <th class="ht-bca-th-floor">Dorm / Floor</th>
                {% for night in bcNights %}
                    <th>{{ night }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
        {% for floor in bcFloors %}
            <tr>
                <td class="ht-bca-floor-label">{{ floor.dorm }} — Floor {{ floor.floor }}</td>
                {% for night in bcNights %}
                    {% set key = floor.dorm ~ '|||' ~ floor.floor ~ '|||' ~ night %}
                    <td class="ht-bca-cell" data-dorm="{{ floor.dorm }}" data-floor="{{ floor.floor }}" data-night="{{ night }}">
                        <div class="ht-bca-chips">
                            {% if bcAssignments[key] is defined %}
                                {% for a in bcAssignments[key] %}
                                    <span class="ht-bca-chip" data-id="{{ a.id }}">
                                        {{ a.staffName }}
                                        <button class="ht-bca-remove" data-id="{{ a.id }}" aria-label="Remove">&times;</button>
                                    </span>
                                {% endfor %}
                            {% endif %}
                        </div>
                        <button class="ht-bca-add" title="Add staff">+</button>
                    </td>
                {% endfor %}
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{# ── Mobile cards ────────────────────────────────────────── #}
<div class="ht-bca-cards">
    {% for floor in bcFloors %}
        <div class="ht-bca-card">
            <div class="ht-bca-card-header">{{ floor.dorm }} — Floor {{ floor.floor }}</div>
            {% for night in bcNights %}
                {% set key = floor.dorm ~ '|||' ~ floor.floor ~ '|||' ~ night %}
                <div class="ht-bca-card-row" data-dorm="{{ floor.dorm }}" data-floor="{{ floor.floor }}" data-night="{{ night }}">
                    <span class="ht-bca-card-night">{{ night }}</span>
                    <div class="ht-bca-chips">
                        {% if bcAssignments[key] is defined %}
                            {% for a in bcAssignments[key] %}
                                <span class="ht-bca-chip" data-id="{{ a.id }}">
                                    {{ a.staffName }}
                                    <button class="ht-bca-remove" data-id="{{ a.id }}" aria-label="Remove">&times;</button>
                                </span>
                            {% endfor %}
                        {% endif %}
                    </div>
                    <button class="ht-bca-add" title="Add staff">+</button>
                </div>
            {% endfor %}
        </div>
    {% endfor %}
</div>

{# ── Floating picker (lives outside the table, positioned via JS) ── #}
<div id="ht-bca-floating-picker" class="ht-bca-floating-picker">
    <input type="text" id="ht-bca-floating-input" placeholder="Search staff…">
</div>

{% endif %}
{% endif %}

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {

    // ── Inline editing for text assignment tabs ──────────────
    const updateUrl = '{{ path("app_user_duty_assignment_update") }}';
    let activeEditor = null; // track the active Tom Select or textarea

    // Predefined assignment options per tab (alphabetical)
    var assignmentOptions = {% if tab == 'checkin' %}[
        "Bus Chaperone",
        "Dorm Greeter",
        "Floater",
        "Floater/Speaker Prep",
        "Flow Manager",
        "Golf Cart Transport",
        "HOBY Store",
        "Icebreakers",
        "Interviews",
        "Key Table",
        "Meds Table",
        "Parking Lot Greeter",
        "Registration",
        "Traffic Director"
    ]{% elseif tab == 'checkout' %}[
        "Check-Out Table",
        "HOBY Store",
        "Meds Table",
        "Staff Lounge Cleanup",
        "Staff Lounge Cleanup Manager"
    ]{% elseif tab == 'cc' %}[
        "Ambassador Lineup Manager",
        "Door Holder",
        "Extra Hands Where Needed",
        "Flow Manager",
        "Parking Lot Greeter",
        "Parking Lot/McCoy Area Manager",
        "Roving Problem Solver"
    ]{% else %}[]{% endif %};

    // Client-side search filter
    document.querySelectorAll('.ht-da-filter-input').forEach(function(input) {
        input.addEventListener('input', function() {
            const q = this.value.toLowerCase();
            const table = this.closest('.ht-da-filter').nextElementSibling.querySelector('.ht-da-table');
            if (!table) return;
            table.querySelectorAll('tbody tr').forEach(function(row) {
                const text = row.dataset.search || '';
                row.style.display = text.includes(q) ? '' : 'none';
            });
        });
    });

    // Click on editable cell → create editor
    document.addEventListener('click', function(e) {
        const cell = e.target.closest('.ht-da-editable');
        if (!cell || cell.querySelector('input, textarea, .ts-wrapper')) return;
        if (e.target.closest('a')) return;

        // Close any other active editor first
        closeActiveEditor();

        const staffId = cell.dataset.staffId;
        const field   = cell.dataset.field;
        const isNotes = cell.classList.contains('ht-da-notes');
        const isAssignment = cell.classList.contains('ht-da-assignment');
        const currentValue = cell.textContent.trim();

        cell.classList.add('ht-da-editing');

        if (isAssignment) {
            // Tom Select with create mode for assignments
            const input = document.createElement('input');
            input.type = 'text';
            input.id = 'ht-da-ts-input-' + staffId + '-' + field;
            cell.textContent = '';
            cell.appendChild(input);

            var ts = new TomSelect(input, {
                create: true,
                createOnBlur: true,
                maxItems: 1,
                options: assignmentOptions.map(function(v) { return { value: v, text: v }; }),
                items: currentValue ? [currentValue] : [],
                valueField: 'value',
                labelField: 'text',
                searchField: 'text',
                placeholder: 'Select or type…',
                onChange: function(value) {
                    saveCellValue(cell, value || '', staffId, field, ts);
                },
                onBlur: function() {
                    // If nothing was selected and user just blurred away, close
                    setTimeout(function() {
                        if (activeEditor === ts) {
                            var v = ts.getValue();
                            if (v === currentValue || (v === '' && currentValue === '')) {
                                cancelEditor(cell, currentValue, ts);
                            }
                        }
                    }, 150);
                },
                render: {
                    option_create: function(data, escape) {
                        return '<div class="create">Add: <strong>' + escape(data.input) + '</strong></div>';
                    }
                }
            });

            activeEditor = ts;
            ts.focus();
            ts.open();

        } else if (isNotes) {
            const textarea = document.createElement('textarea');
            textarea.className = 'ht-da-input';
            textarea.value = currentValue;
            textarea.rows = 2;
            cell.textContent = '';
            cell.appendChild(textarea);
            activeEditor = textarea;
            textarea.focus();
            textarea.addEventListener('blur', function() {
                saveCellValue(cell, textarea.value, staffId, field, null);
            });
            textarea.addEventListener('keydown', function(ev) {
                if (ev.key === 'Escape') { ev.preventDefault(); cancelEditor(cell, currentValue, null); }
            });
        }
    });

    function saveCellValue(cell, newValue, staffId, field, tsInstance) {
        newValue = newValue.trim();
        var oldValue = cell.dataset.lastValue || '';

        var formData = new FormData();
        formData.append('id', staffId);
        formData.append('field', field);
        formData.append('value', newValue);

        fetch(updateUrl, { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    finishEditor(cell, newValue, tsInstance);
                    cell.classList.add('ht-da-saved');
                    setTimeout(function() { cell.classList.remove('ht-da-saved'); }, 800);
                } else {
                    finishEditor(cell, oldValue, tsInstance);
                    cell.classList.add('ht-da-error');
                    setTimeout(function() { cell.classList.remove('ht-da-error'); }, 800);
                }
            })
            .catch(function() {
                finishEditor(cell, oldValue, tsInstance);
                cell.classList.add('ht-da-error');
                setTimeout(function() { cell.classList.remove('ht-da-error'); }, 800);
            });
    }

    function finishEditor(cell, value, tsInstance) {
        if (tsInstance) { try { tsInstance.destroy(); } catch(e) {} }
        cell.textContent = value;
        cell.dataset.lastValue = value;
        cell.classList.remove('ht-da-editing');
        activeEditor = null;
    }

    function cancelEditor(cell, originalValue, tsInstance) {
        finishEditor(cell, originalValue, tsInstance);
    }

    function closeActiveEditor() {
        if (!activeEditor) return;
        var cell = activeEditor instanceof TomSelect
            ? activeEditor.wrapper?.closest('.ht-da-editable')
            : activeEditor.closest?.('.ht-da-editable');
        if (cell) {
            var originalValue = cell.dataset.lastValue || '';
            if (activeEditor instanceof TomSelect) {
                cancelEditor(cell, originalValue, activeEditor);
            } else {
                cancelEditor(cell, originalValue, null);
            }
        }
    }

    // Escape key closes any active editor
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeActiveEditor();
    });

    // Store initial values
    document.querySelectorAll('.ht-da-editable').forEach(function(cell) {
        cell.dataset.lastValue = cell.textContent.trim();
    });

    // ── Bed check assignments (existing) ────────────────────
    const searchUrl  = '{{ path("bedcheck_assignments_search") }}';
    const addUrl     = '{{ path("bedcheck_assignments_add") }}';
    const removeBase = '{{ path("bedcheck_assignments_remove", {id: "__ID__"}) }}';

    const floatingPicker = document.getElementById('ht-bca-floating-picker');
    if (!floatingPicker) return;

    let activePicker = null;
    let activeContainer = null;

    // ── Add button click: position floating picker near the button ──
    document.addEventListener('click', function(e) {
        const addBtn = e.target.closest('.ht-bca-add');
        if (!addBtn) return;
        e.stopPropagation();
        closePicker();

        activeContainer = addBtn.closest('.ht-bca-cell, .ht-bca-card-row');
        const rect = addBtn.getBoundingClientRect();

        floatingPicker.style.display = 'block';
        floatingPicker.style.top  = (rect.bottom + window.scrollY + 4) + 'px';
        floatingPicker.style.left = (rect.left + window.scrollX) + 'px';

        activePicker = new TomSelect(document.getElementById('ht-bca-floating-input'), {
            valueField: 'id',
            labelField: 'name',
            searchField: 'name',
            placeholder: 'Search staff…',
            openOnFocus: true,
            load: function(query, callback) {
                if (query.length < 1) return callback();
                fetch(searchUrl + '?q=' + encodeURIComponent(query))
                    .then(r => r.json())
                    .then(data => callback(data))
                    .catch(() => callback());
            },
            onItemAdd: function(value, item) {
                const dorm  = activeContainer.dataset.dorm;
                const floor = activeContainer.dataset.floor;
                const night = activeContainer.dataset.night;

                const formData = new FormData();
                formData.append('staff_assignment_id', value);
                formData.append('dorm', dorm);
                formData.append('floor', floor);
                formData.append('night', night);

                fetch(addUrl, { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            const chips = activeContainer.querySelector('.ht-bca-chips');
                            const chip = document.createElement('span');
                            chip.className = 'ht-bca-chip';
                            chip.dataset.id = data.id;
                            chip.innerHTML = data.name +
                                ' <button class="ht-bca-remove" data-id="' + data.id + '" aria-label="Remove">&times;</button>';
                            chips.appendChild(chip);
                        }
                        closePicker();
                    })
                    .catch(() => closePicker());
            },
            render: {
                no_results: function() {
                    return '<div class="no-results">No staff found</div>';
                }
            }
        });

        activePicker.focus();
    });

    // ── Remove button click ──
    document.addEventListener('click', function(e) {
        const removeBtn = e.target.closest('.ht-bca-remove');
        if (!removeBtn) return;
        const id = removeBtn.dataset.id;
        fetch(removeBase.replace('__ID__', id), { method: 'POST' })
            .then(r => r.json())
            .then(data => { if (data.success) removeBtn.closest('.ht-bca-chip').remove(); });
    });

    // ── Close picker ──
    function closePicker() {
        if (activePicker) {
            activePicker.destroy();
            activePicker = null;
            floatingPicker.innerHTML = '<input type="text" id="ht-bca-floating-input" placeholder="Search staff…">';
        }
        floatingPicker.style.display = 'none';
        activeContainer = null;
    }

    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closePicker(); });
    document.addEventListener('click', function(e) {
        if (activePicker && !e.target.closest('.ht-bca-floating-picker, .ht-bca-add, .ts-dropdown')) closePicker();
    });
});
</script>
{% endblock %}
