{% extends 'base.html.twig' %}

{% block body %}
    <h1>Staff</h1>

    <table class="standard-view table table-striped table-bordered" id="staff-table">
        <thead>
            <tr>
                <th class="no-export">View</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Position</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
                <tr>
                    <td class="view-link"><a href="{{ path('app_user_show', { 'id': user.userId }) }}">{{ global_view_link | raw }}</a></td>
                    <td>{{ user.consolidatedFirstName }}</td>
                    <td>{{ user.lastName }}</td>
                    <td>{{ user.position }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

{% endblock %}
