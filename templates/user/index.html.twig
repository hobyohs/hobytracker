{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}

{% block body %}

{# Build sorted list of letter groups present in this year's staff #}
{% set groups_map = {} %}
{% for user in users %}
    {% if user.letterGroup %}
        {% set groups_map = groups_map|merge({ (user.letterGroup.letter): user.letterGroup }) %}
    {% endif %}
{% endfor %}
{% set sorted_letters = groups_map|keys|sort %}

<div class="ht-page-header">
    <h1>Staff</h1>
    <span class="ht-page-count">{{ users|length }}</span>
</div>

<div class="ht-list-controls">
    <input type="text" id="staffSearch" class="ht-search-input" placeholder="Search name, position, group…" autocomplete="off" autocorrect="off" spellcheck="false">
    <div class="ht-filter-pills">
        <span class="ht-pill staff-pill active" data-filter="all">All</span>
        {% for letter in sorted_letters %}
            <span class="ht-pill staff-pill" data-filter="{{ letter }}">{{ letter }}</span>
        {% endfor %}
    </div>
</div>

<div class="ht-card-list" id="staffList">
    {% for user in users %}
        {%- set groupLetter = user.letterGroup ? user.letterGroup.letter : '' -%}
        {%- set groupColor  = user.letterGroup ? user.letterGroup.color  : '' -%}
        <a href="{{ path('app_user_show', { 'id': user.userId }) }}"
           class="ht-card-row"
           data-name="{{ (user.consolidatedFirstName ~ ' ' ~ user.lastName)|lower }}"
           data-sub="{{ user.position|lower }}"
           data-group="{{ groupLetter }}">
            {{ avatar.render(user) }}
            <div class="ht-card-info">
                <div class="ht-card-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</div>
                <div class="ht-card-sub">{{ user.position }}</div>
            </div>
            {% if user.letterGroup %}
                <span class="ht-group-badge ht-group-{{ groupColor }}">{{ groupLetter }}</span>
            {% endif %}
            <span class="ht-chevron">›</span>
        </a>
    {% else %}
        <div class="ht-no-results" style="display:block;">No staff found.</div>
    {% endfor %}
    <div class="ht-no-results">No results match your search.</div>
</div>

{% endblock %}
