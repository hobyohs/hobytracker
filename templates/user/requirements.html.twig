{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}
{% block maintag %}<main class="wide">{% endblock %}
{% block body %}
<div class="ht-page-header"><h1>Staff Requirements</h1></div>
<div class="ht-page-subtitle">Last update: {{ lastUpdated }}</div>
<div class="ht-dt-card ht-responsive-table">
    <table class="table" id="staff-req-table">
        <thead><tr>
            <th class="ht-avatar-col no-export"></th>
            <th>First Name</th><th class="ht-mobile-hide">Last Name</th><th class="ht-mobile-hide">Position</th>
            <th class="hidden">Email</th>
            <th>Paperwork</th><th>BG Check</th><th>HOBY App</th>
            <th>Hours</th><th>Amb Registered</th><th>Fundraising</th><th class="none">Notes</th>
            <th class="no-export ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for user in users %}
                <tr data-href="{{ path('app_user_show', { 'id': user.userId }) }}">
                    <td class="ht-avatar-col no-export">{{ avatar.render(user, 32) }}</td>
                    <td data-label="First" class="ht-name-td">
                        <span class="ht-name-desktop">{{ user.consolidatedFirstName }}</span>
                        <span class="ht-name-mobile-header">
                            {{ avatar.render(user, 36) }}
                            <span class="ht-card-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</span>
                            {% if user.position %}<span class="ht-group-badge ht-card-name-badge" style="background:#eef1f4;color:#555;font-size:10px;">{{ user.position }}</span>{% endif %}
                        </span>
                    </td>
                    <td data-label="Last" class="ht-mobile-hide">{{ user.lastName }}</td>
                    <td data-label="Position" class="ht-mobile-hide">{{ user.position }}</td>
                    <td class="hidden">{{ user.email }}</td>
                    {% if user.isPaperworkComplete %}<td data-label="Paperwork" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% else %}<td data-label="Paperwork" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>{% endif %}
                    {% if user.isBgCheckComplete %}<td data-label="BG Check" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% elseif user.isBgCheckSubmitted %}<td data-label="BG Check" class="gridblock pray"><span class="fa fa-clock"><span class="hidden">PENDING</span></span></td>
                    {% elseif user.controlledAge >= 18 %}<td data-label="BG Check" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>
                    {% else %}<td data-label="BG Check" class="gridblock okay">&nbsp;</td>{% endif %}
                    {% if user.isHobyAppComplete %}<td data-label="HOBY App" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% else %}<td data-label="HOBY App" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>{% endif %}
                    {% if user.isHoursComplete %}<td data-label="Hours" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% elseif user.controlledAge < 21 %}<td data-label="Hours" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>
                    {% else %}<td data-label="Hours" class="gridblock okay">&nbsp;</td>{% endif %}
                    {% if user.isAmbRegistered %}<td data-label="Amb Reg" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% elseif user.controlledAge < 21 %}<td data-label="Amb Reg" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>
                    {% else %}<td data-label="Amb Reg" class="gridblock okay">&nbsp;</td>{% endif %}
                    {% if user.isFundraisingComplete %}<td data-label="Fundraising" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% else %}<td data-label="Fundraising" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>{% endif %}
                    <td data-label="Notes">{{ user.requirementNotes }}</td>
                    <td class="no-export ht-chevron-col"><a href="{{ path('app_user_show', { 'id': user.userId }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
