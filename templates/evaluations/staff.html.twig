{% extends 'base.html.twig' %}
{% block maintag %}<main class="wide">{% endblock %}
{% block body %}
<a href="{{ path('app_letter_group_show', {'letter': group.letter}) }}" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> Group {{ group.letter }}
</a>
<div class="ht-page-header"><h1>{{ group.printLetterGroup | raw }} &mdash; Co-Facilitator Evaluations</h1></div>
<div class="ht-dt-card">
    <table class="table" id="my-group-se-table">
        <thead><tr>
            <th>View</th><th>First Name</th><th>Last Name</th><th>Role</th><th>Completed?</th>
        </tr></thead>
        <tbody>
            {% for fac in group.facilitators %}
                {% if fac.userId != app.user.id %}
                    <tr>
                        <td class="view-link"><a href="{{ path('staffeval_edit', { 'id': fac.id }) }}"><span class="fa fa-pencil"></span></a></td>
                        <td>{{fac.consolidatedFirstName}}</td><td>{{fac.lastName}}</td>
                        <td>{{fac.position}}</td>
                        <td>{% if fac.evalStatus == 1 %}Yes{% elseif fac.evalStatus == 0 and fac.evalStatus is not null %}No{% endif %}</td>
                    </tr>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
