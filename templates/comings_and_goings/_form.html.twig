{# Shared form body for new + edit comings/going. Expects: form, title, back_label #}
<a href="{{ path('app_comings_and_goings_index') }}" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> {{ back_label|default('Comings & Goings') }}
</a>

<div class="ht-form-page">
    <h1 class="ht-form-title">{{ title }}</h1>

    {{ form_start(form, { 'attr': { 'class': 'ht-form', 'novalidate': 'novalidate' } }) }}

        <div class="ht-form-row">
            {{ form_label(form.ambassador, 'Ambassador', { 'label_attr': { 'class': 'ht-form-label' } }) }}
            {{ form_widget(form.ambassador, { 'attr': { 'class': 'ht-form-input ht-tomselect' } }) }}
            {{ form_errors(form.ambassador) }}
        </div>

        <div class="ht-form-row">
            {{ form_label(form.departure, 'Leaving seminar', { 'label_attr': { 'class': 'ht-form-label' } }) }}
            <div class="ht-form-help">When the ambassador will be picked up and leave. Leave blank if this is a return only.</div>
            {{ form_widget(form.departure, { 'attr': { 'class': 'ht-form-input' } }) }}
            {{ form_errors(form.departure) }}
        </div>

        <div class="ht-form-row">
            {{ form_label(form.arrival, 'Returning to seminar', { 'label_attr': { 'class': 'ht-form-label' } }) }}
            <div class="ht-form-help">When the ambassador will be returned. Leave blank if this is a departure only.</div>
            {{ form_widget(form.arrival, { 'attr': { 'class': 'ht-form-input' } }) }}
            {{ form_errors(form.arrival) }}
        </div>

        <div class="ht-form-row">
            {{ form_label(form.notes, 'Notes', { 'label_attr': { 'class': 'ht-form-label' } }) }}
            {{ form_widget(form.notes, { 'attr': { 'class': 'ht-form-input', 'rows': 4, 'placeholder': 'Optional — who is picking them up, reason, contact info, etc.' } }) }}
            {{ form_errors(form.notes) }}
        </div>

        <div class="ht-form-actions">
            <button type="submit" class="ht-btn ht-btn-primary">{{ button_label|default('Save') }}</button>
            <a href="{{ path('app_comings_and_goings_index') }}" class="ht-btn ht-btn-secondary">Cancel</a>
        </div>

    {{ form_end(form) }}
</div>
