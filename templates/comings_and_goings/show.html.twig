{% extends 'base.html.twig' %}

{% block body %}
    <h1>Comingsandgoing</h1>

    <table>
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ comingsAndGoing.id }}</td>
            </tr>
            <tr>
                <th>Departure</th>
                <td>{% if comingsAndGoing.departure %}{{ comingsAndGoing.departure|date('Y-m-d H:i:s') }}{% endif %}</td>
            </tr>
            <tr>
                <th>Arrival</th>
                <td>{% if comingsAndGoing.arrival %}{{ comingsAndGoing.arrival|date('Y-m-d H:i:s') }}{% endif %}</td>
            </tr>
            <tr>
                <th>Checked_out</th>
                <td>{% if comingsAndGoing.checkedout %}Yes{% else %}No{% endif %}</td>
            </tr>
            <tr>
                <th>Checked_in</th>
                <td>{% if comingsAndGoing.checkedin %}Yes{% else %}No{% endif %}</td>
            </tr>
        </tbody>
    </table>

    <ul>
        <li>
            <a href="{{ path('app_comings_and_goings_index') }}">Back to the list</a>
        </li>
        <li>
            <a href="{{ path('app_comings_and_goings_edit', { 'id': comingsAndGoing.id }) }}">Edit</a>
        </li>
        <li>
            {{ form_start(delete_form) }}
                <input type="submit" value="Delete">
            {{ form_end(delete_form) }}
        </li>
    </ul>
{% endblock %}
