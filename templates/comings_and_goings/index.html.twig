{% extends 'base.html.twig' %}
{% block maintag %}<main class="wide">{% endblock %}
{% block body %}
<div class="ht-page-header"><h1>Comings &amp; Goings</h1></div>
<div class="ht-dt-card">
    <table class="table" id="cg-table">
        <thead><tr>
            <th>First Name</th><th>Last Name</th><th>Group</th>
            <th>Form</th><th>Departure</th><th>Return</th><th>Notes</th>
            {% if is_granted('ROLE_BOARD') %}<th class="no-export"></th>{% endif %}
        </tr></thead>
        <tbody>
            {% for cg in comings_and_goings %}
                <tr>
                    <td><a href="{{ path('app_ambassador_show', { 'id': cg.ambassador.id }) }}" class="ht-table-name-link">{{ cg.ambassador.consolidatedFirstName }}</a></td>
                    <td>{{ cg.ambassador.lastName }}</td>
                    <td class="center">{% if not cg.ambassador.letterGroup is empty %}<a href="{{ path('app_letter_group_show', { 'letter': cg.ambassador.letterGroup.letter }) }}" class="letter {{cg.ambassador.letterGroup.color}}">{{ cg.ambassador.letterGroup.letter }}</a>{% endif %}</td>
                    {% if cg.ambassador.isCgForm %}<td class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% elseif cg.ambassador.comingsAndGoings|length > 0 %}<td class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>
                    {% else %}<td class="gridblock okay">&nbsp;</td>{% endif %}
                    <td>
                        {% if cg.departure is not null %}
                            {{ cg.departure|date('D M j \\a\\t g:iA') }}<br>
                            <input type="checkbox" data-cg-id="{{cg.id}}" data-field="checked_out" class="cg-checkbox"{% if cg.isCheckedOut %} checked disabled{% endif %}>&nbsp;<span id="{{cg.id}}-checked_out-by" class="byline">{% if cg.isCheckedOut and cg.departure is not null %}by {{cg.checkedOutBy}}{% endif %}</span>
                        {% else %}N/A{% endif %}
                    </td>
                    <td>
                        {% if cg.arrival is not null %}
                            {{ cg.arrival|date('D M j \\a\\t g:iA') }}<br>
                            <input type="checkbox" data-cg-id="{{cg.id}}" data-field="checked_in" class="cg-checkbox"{% if cg.isCheckedIn %} checked disabled{% endif %}>&nbsp;<span id="{{cg.id}}-checked_in-by" class="byline">{% if cg.isCheckedIn and cg.arrival is not null %}by {{cg.checkedInBy}}{% endif %}</span>
                        {% else %}N/A{% endif %}
                    </td>
                    <td>{{cg.notes}}</td>
                    {% if is_granted('ROLE_BOARD') %}
                        <td class="center"><a href="{{ path('app_comings_and_goings_edit', { 'id': cg.id }) }}" class="ht-table-edit-link" title="Edit"><span class="fa fa-pencil"></span></a></td>
                    {% endif %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="text/javascript">
        $(document).ready(function() {
            $('input.cg-checkbox').change(function() {
                var field_status = $(this).is(":checked") ? 1 : 0;
                $.post("{{ path('cg_update') }}", {
                    cg_id: $(this).data('cg-id'),
                    field: $(this).data('field'),
                    field_status: field_status
                });
                $(this).attr("disabled", true);
                $("#"+$(this).data('cg-id')+"-"+$(this).data('field')+"-by").text("by {{app.user.firstName}} {{app.user.lastName}}");
            });

            $('table#cg-table').DataTable({
                "order": [[4, "asc"], [1, "asc"]],
                "columnDefs": [
                    { responsivePriority: 1, targets: 0 },
                    { responsivePriority: 2, targets: 1 },
                    { responsivePriority: 3, targets: 4 },
                    { responsivePriority: 4, targets: 5 }
                    {% if is_granted('ROLE_BOARD') %}, { targets: 7, orderable: false }{% endif %}
                ],
                buttons: [
                    {% if is_granted('ROLE_BOARD') %}
                    { text: 'New', action: function(e, dt, node, config) { window.location.href = "{{ path('app_comings_and_goings_new') }}"; } },
                    {% endif %}
                    'excelHtml5', 'print'
                ]
            });
        });
    </script>
{% endblock %}
