{% extends 'base.html.twig' %}

{% block maintag %}<main class="show ambassador">{% endblock %}

{% block body %}

{%- set initials = ambassador.consolidatedFirstName[0:1]|upper ~ ambassador.lastName[0:1]|upper -%}
{%- set groupColor = ambassador.letterGroup ? ambassador.letterGroup.color : '' -%}

<a href="{{ path('app_ambassador_index') }}" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> Ambassadors
</a>

{# ── Header ─────────────────────────────────────────────── #}
<div class="ht-show-header">
    {% if ambassador.photo %}
        <img src="{{ ambassador.photo }}" alt="{{ ambassador.fullName }}" class="ht-show-avatar">
    {% else %}
        <div class="ht-show-avatar-initials">{{ initials }}</div>
    {% endif %}

    <div class="ht-show-name">{{ ambassador.consolidatedFirstName }} {{ ambassador.lastName }}</div>
    <div class="ht-show-subtitle">{{ ambassador.school }}</div>

    <div class="ht-show-badges">
        {% if ambassador.letterGroup %}
            <a href="{{ path('app_letter_group_show', { 'letter': ambassador.letterGroup.letter }) }}"
               class="ht-group-badge ht-group-badge-lg ht-group-{{ groupColor }}"
               style="text-decoration:none;">
               Group {{ ambassador.letterGroup.letter }}
            </a>
        {% else %}
            <span class="ht-room-badge" style="color:#bbb;">No group assigned</span>
        {% endif %}
        {% if ambassador.dormRoom %}
            <span class="ht-room-badge">{{ ambassador.dorm }} {{ ambassador.room }}</span>
        {% endif %}
    </div>
</div>

<div class="ht-show-body">

{# ── Personal Information ────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Contact</div>
    <div class="ht-section-card">
        {% if ambassador.prefName and ambassador.prefName != ambassador.firstName %}
            <div class="ht-section-row">
                <span class="ht-section-key">Preferred name</span>
                <span class="ht-section-val">{{ ambassador.prefName }}</span>
            </div>
        {% endif %}
        <div class="ht-section-row">
            <span class="ht-section-key">Full name</span>
            <span class="ht-section-val">{{ ambassador.firstName }} {{ ambassador.lastName }}</span>
        </div>
        {% if ambassador.pronouns %}
            <div class="ht-section-row">
                <span class="ht-section-key">Pronouns</span>
                <span class="ht-section-val">{{ ambassador.pronouns }}</span>
            </div>
        {% endif %}
        {% if ambassador.cellPhone %}
            <div class="ht-section-row">
                <span class="ht-section-key">Cell phone</span>
                <span class="ht-section-val">{{ ambassador.cellPhone }}</span>
            </div>
        {% endif %}
        {% if ambassador.homePhone %}
            <div class="ht-section-row">
                <span class="ht-section-key">Home phone</span>
                <span class="ht-section-val">{{ ambassador.homePhone }}</span>
            </div>
        {% endif %}
        {% if ambassador.email %}
            <div class="ht-section-row">
                <span class="ht-section-key">Email</span>
                <span class="ht-section-val">{{ ambassador.email }}</span>
            </div>
        {% endif %}
        {% if ambassador.county %}
            <div class="ht-section-row">
                <span class="ht-section-key">County</span>
                <span class="ht-section-val">{{ ambassador.county }}</span>
            </div>
        {% endif %}
        {% if ambassador.shirtSize %}
            <div class="ht-section-row">
                <span class="ht-section-key">Shirt size</span>
                <span class="ht-section-val">{{ ambassador.shirtSize }}</span>
            </div>
        {% endif %}
    </div>
</div>

{# ── Seminar Status ──────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Seminar status</div>
    <div class="ht-section-card">
        <div class="ht-section-row">
            <span class="ht-section-key">PSMs received</span>
            {% if ambassador.psmsUploadedOn %}
                <span class="ht-status-dot ht-yes">✓</span>
            {% else %}
                <span class="ht-status-dot ht-no">✗</span>
            {% endif %}
        </div>
        <div class="ht-section-row">
            <span class="ht-section-key">Checked in</span>
            {% if ambassador.checkedIn %}
                <span class="ht-status-dot ht-yes">✓</span>
            {% else %}
                <span class="ht-status-dot ht-no">✗</span>
            {% endif %}
        </div>
        <div class="ht-section-row">
            <span class="ht-section-key">Key deposit</span>
            {% if ambassador.checkinDeposit %}
                <span class="ht-status-dot ht-yes">✓</span>
            {% else %}
                <span class="ht-status-dot ht-no">✗</span>
            {% endif %}
        </div>
        <div class="ht-section-row">
            <span class="ht-section-key">Checked out</span>
            {% if ambassador.checkedOut %}
                <span class="ht-status-dot ht-yes">✓</span>
            {% else %}
                <span class="ht-status-dot ht-no">✗</span>
            {% endif %}
        </div>
    </div>
</div>

{# ── Parent / Guardian & Emergency Contact (board or own-group facilitator) #}
{% if is_granted('ROLE_BOARD') or (app.user.isSeniorOps and app.user.letterGroup == ambassador.letterGroup) %}

    {% if ambassador.parent1FirstName %}
    <div class="ht-section">
        <div class="ht-section-label">Parent / Guardian 1</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Name</span>
                <span class="ht-section-val">{{ ambassador.parent1FirstName }} {{ ambassador.parent1LastName }}</span>
            </div>
            {% if ambassador.parent1Phone1 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Phone</span>
                    <span class="ht-section-val">{{ ambassador.parent1Phone1 }}</span>
                </div>
            {% endif %}
            {% if ambassador.parent1Phone2 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Alt phone</span>
                    <span class="ht-section-val">{{ ambassador.parent1Phone2 }}</span>
                </div>
            {% endif %}
            {% if ambassador.parent1Email %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Email</span>
                    <span class="ht-section-val">{{ ambassador.parent1Email }}</span>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if ambassador.parent2FirstName %}
    <div class="ht-section">
        <div class="ht-section-label">Parent / Guardian 2</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Name</span>
                <span class="ht-section-val">{{ ambassador.parent2FirstName }} {{ ambassador.parent2LastName }}</span>
            </div>
            {% if ambassador.parent2Phone1 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Phone</span>
                    <span class="ht-section-val">{{ ambassador.parent2Phone1 }}</span>
                </div>
            {% endif %}
            {% if ambassador.parent2Phone2 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Alt phone</span>
                    <span class="ht-section-val">{{ ambassador.parent2Phone2 }}</span>
                </div>
            {% endif %}
            {% if ambassador.parent2Email %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Email</span>
                    <span class="ht-section-val">{{ ambassador.parent2Email }}</span>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% if ambassador.ecFirstName %}
    <div class="ht-section">
        <div class="ht-section-label">Emergency Contact</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Name</span>
                <span class="ht-section-val">{{ ambassador.ecFirstName }} {{ ambassador.ecLastName }}</span>
            </div>
            {% if ambassador.ecRelationship %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Relationship</span>
                    <span class="ht-section-val">{{ ambassador.ecRelationship }}</span>
                </div>
            {% endif %}
            {% if ambassador.ecPhone1 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Phone</span>
                    <span class="ht-section-val">{{ ambassador.ecPhone1 }}</span>
                </div>
            {% endif %}
            {% if ambassador.ecPhone2 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Alt phone</span>
                    <span class="ht-section-val">{{ ambassador.ecPhone2 }}</span>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    <div class="ht-section">
        <div class="ht-section-label">Dietary &amp; Health</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Restrictions</span>
                <span class="ht-section-val{% if not ambassador.dietRestrictions %} ht-empty{% endif %}">
                    {{ ambassador.dietRestrictions ?: 'None' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Dietary info</span>
                <span class="ht-section-val{% if not ambassador.dietInfo %} ht-empty{% endif %}">
                    {{ ambassador.dietInfo ?: 'None' }}
                </span>
            </div>
            {% if ambassador.dietSeverity %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Severity</span>
                    <span class="ht-section-val">{{ ambassador.dietSeverity }}</span>
                </div>
            {% endif %}
            <div class="ht-section-row">
                <span class="ht-section-key">Allergies</span>
                <span class="ht-section-val{% if not ambassador.allergies %} ht-empty{% endif %}">
                    {{ ambassador.allergies ?: 'None' }}
                </span>
            </div>
            {% if ambassador.currentConditions %}
                <div class="ht-section-row-block ht-section-row">
                    <span class="ht-section-key">Current conditions</span>
                    <span class="ht-section-val">{{ ambassador.currentConditions }}</span>
                </div>
            {% endif %}
            {% if ambassador.exerciseLimits %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Exercise limits</span>
                    <span class="ht-section-val">{{ ambassador.exerciseLimits }}</span>
                </div>
            {% endif %}
        </div>
    </div>

{% endif %}

{# ── Medical (nurse only) ────────────────────────────────── #}
{% if is_granted('ROLE_NURSE') %}
    <div class="ht-section">
        <div class="ht-section-label">Medical</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Med allergies</span>
                <span class="ht-section-val{% if not ambassador.medAllergies %} ht-empty{% endif %}">
                    {{ ambassador.medAllergies ?: 'None' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Current Rx</span>
                <span class="ht-section-val{% if not ambassador.currentRx %} ht-empty{% endif %}">
                    {{ ambassador.currentRx ?: 'None' }}
                </span>
            </div>
            {% if ambassador.approvedOtc %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Approved OTC</span>
                    <span class="ht-section-val">{{ ambassador.approvedOtc }}</span>
                </div>
            {% endif %}
        </div>
    </div>
{% endif %}

{# ── Bus Info ────────────────────────────────────────────── #}
{% if ambassador.takingBus %}
    <div class="ht-section">
        <div class="ht-section-label">Bus</div>
        <div class="ht-section-card">
            {% if ambassador.busToContact %}
                <div class="ht-section-row">
                    <span class="ht-section-key">To seminar contact</span>
                    <span class="ht-section-val">{{ ambassador.busToContact }}</span>
                </div>
                <div class="ht-section-row">
                    <span class="ht-section-key">To seminar phone</span>
                    <span class="ht-section-val">{{ ambassador.busToPhone }}</span>
                </div>
            {% endif %}
            {% if ambassador.busFromContact %}
                <div class="ht-section-row">
                    <span class="ht-section-key">From seminar contact</span>
                    <span class="ht-section-val">{{ ambassador.busFromContact }}</span>
                </div>
                <div class="ht-section-row">
                    <span class="ht-section-key">From seminar phone</span>
                    <span class="ht-section-val">{{ ambassador.busFromPhone }}</span>
                </div>
            {% endif %}
        </div>
    </div>
{% endif %}
{% if ambassador.activeComingsAndGoings|length > 0 or is_granted('ROLE_BOARD') %}
<div class="ht-section">
    <div class="ht-section-label" style="display:flex; justify-content:space-between; align-items:center;">
        <span>Comings &amp; Goings</span>
        {% if is_granted('ROLE_BOARD') %}
            <a href="{{ path('app_comings_and_goings_new', {'ambassador_id': ambassador.id}) }}" class="ht-btn ht-btn-secondary" style="font-size:12px; padding:4px 10px;">
                <i class="fa fa-plus"></i> Add
            </a>
        {% endif %}
    </div>
    {% if ambassador.activeComingsAndGoings|length == 0 %}
        <div class="ht-section-card">
            <div class="ht-section-row"><span class="ht-section-val ht-empty">None on file</span></div>
        </div>
    {% else %}
        <div class="ht-cg-cards" style="gap:8px;">
        {% for cg in ambassador.activeComingsAndGoings %}
            <div class="ht-cg-card" id="cg-card-{{ cg.id }}">
                {% if cg.notes %}
                    <div class="ht-cg-notes">{{ cg.notes }}</div>
                {% endif %}
                {% if cg.departure is not null %}
                    <div class="ht-cg-block {{ cg.isCheckedOut ? 'is-confirmed' : '' }}" id="cg-out-{{ cg.id }}">
                        <div class="ht-cg-block-meta">
                            <span class="ht-cg-block-label">Leaving</span>
                            <span class="ht-cg-block-time">{{ cg.departure|date('D M j \\a\\t g:iA') }}</span>
                        </div>
                        <div class="ht-cg-block-action">
                            {% if cg.isCheckedOut %}
                                <span class="ht-cg-confirmed-label"><i class="fa fa-check"></i> Checked out</span>
                                <span class="ht-cg-by">by {{ cg.checkedOutBy }}</span>
                                <button type="button" class="ht-cg-undo-btn" data-cg-id="{{ cg.id }}" data-field="checked_out">Undo</button>
                            {% else %}
                                <button type="button" class="ht-cg-action-btn" data-cg-id="{{ cg.id }}" data-field="checked_out">
                                    <i class="fa fa-arrow-right-from-bracket"></i> Check Out
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
                {% if cg.arrival is not null %}
                    <div class="ht-cg-block {{ cg.isCheckedIn ? 'is-confirmed' : '' }}" id="cg-in-{{ cg.id }}">
                        <div class="ht-cg-block-meta">
                            <span class="ht-cg-block-label">Returning</span>
                            <span class="ht-cg-block-time">{{ cg.arrival|date('D M j \\a\\t g:iA') }}</span>
                        </div>
                        <div class="ht-cg-block-action">
                            {% if cg.isCheckedIn %}
                                <span class="ht-cg-confirmed-label"><i class="fa fa-check"></i> Checked in</span>
                                <span class="ht-cg-by">by {{ cg.checkedInBy }}</span>
                                <button type="button" class="ht-cg-undo-btn" data-cg-id="{{ cg.id }}" data-field="checked_in">Undo</button>
                            {% else %}
                                <button type="button" class="ht-cg-action-btn" data-cg-id="{{ cg.id }}" data-field="checked_in">
                                    <i class="fa fa-arrow-right-to-bracket"></i> Check In
                                </button>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            </div>
        {% endfor %}
        </div>
    {% endif %}
</div>
{% endif %}

</div>{# end ht-show-body #}

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function() {
    var CG_URL  = '{{ path('cg_update') }}';
    var BY_NAME = '{{ app.user.firstName }} {{ app.user.lastName }}';

    document.addEventListener('click', function(e) {
        var actionBtn = e.target.closest('.ht-cg-action-btn');
        var undoBtn   = e.target.closest('.ht-cg-undo-btn');
        if (actionBtn) handleAction(actionBtn);
        if (undoBtn)   handleUndo(undoBtn);
    });

    function handleAction(btn) {
        var cgId = btn.dataset.cgId, field = btn.dataset.field;
        btn.disabled = true;
        post(CG_URL, 'cg_id=' + cgId + '&field=' + field + '&field_status=1')
            .then(function(d) { if (d.success) markConfirmed(cgId, field, BY_NAME); else btn.disabled = false; })
            .catch(function() { btn.disabled = false; });
    }

    function handleUndo(btn) {
        var cgId = btn.dataset.cgId, field = btn.dataset.field;
        btn.disabled = true;
        post(CG_URL, 'cg_id=' + cgId + '&field=' + field + '&field_status=0')
            .then(function(d) { if (d.success) markPending(cgId, field); else btn.disabled = false; })
            .catch(function() { btn.disabled = false; });
    }

    function markConfirmed(cgId, field, byName) {
        var block = document.getElementById(field === 'checked_out' ? 'cg-out-' + cgId : 'cg-in-' + cgId);
        if (!block) return;
        block.classList.add('is-confirmed');
        block.querySelector('.ht-cg-block-action').innerHTML =
            '<span class="ht-cg-confirmed-label"><i class="fa fa-check"></i> ' + (field === 'checked_out' ? 'Checked out' : 'Checked in') + '</span>' +
            '<span class="ht-cg-by">by ' + byName + '</span>' +
            '<button type="button" class="ht-cg-undo-btn" data-cg-id="' + cgId + '" data-field="' + field + '">Undo</button>';
    }

    function markPending(cgId, field) {
        var block = document.getElementById(field === 'checked_out' ? 'cg-out-' + cgId : 'cg-in-' + cgId);
        if (!block) return;
        block.classList.remove('is-confirmed');
        var label = field === 'checked_out' ? '<i class="fa fa-arrow-right-from-bracket"></i> Check Out' : '<i class="fa fa-arrow-right-to-bracket"></i> Check In';
        block.querySelector('.ht-cg-block-action').innerHTML =
            '<button type="button" class="ht-cg-action-btn" data-cg-id="' + cgId + '" data-field="' + field + '">' + label + '</button>';
    }

    function post(url, body) {
        return fetch(url, { method: 'POST', credentials: 'same-origin',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body
        }).then(function(r) { return r.json(); });
    }
})();
</script>
{% endblock %}
