{% extends 'base.html.twig' %}
{% block maintag %}<main class="wide">{% endblock %}
{% block body %}
<div class="ht-page-header"><h1>Bus Report</h1></div>
<div class="ht-dt-card">
    <table class="table" id="bus-table">
        <thead><tr>
            <th>First Name</th><th>Last Name</th><th>Group</th>
            <th>School</th><th>Bus To: Contact</th><th>Bus From: Contact</th>
        </tr></thead>
        <tbody>
            {% for ambassador in ambassadors %}
                <tr>
                    <td><a href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}" class="ht-table-name-link">{{ ambassador.consolidatedFirstName }}</a></td><td>{{ ambassador.lastName }}</td>
                    <td class="center">{% if not ambassador.letterGroup is empty %}<a href="{{ path('app_letter_group_show', { 'letter': ambassador.letterGroup.letter }) }}" class="letter {{ambassador.letterGroup.color}}">{{ ambassador.letterGroup.letter }}</a>{% endif %}</td>
                    <td>{{ ambassador.school }}</td>
                    <td>{% if not ambassador.busToContact is empty %}{{ ambassador.busToContact }}, {{ ambassador.busToPhone }}{% endif %}</td>
                    <td>{% if not ambassador.busFromContact is empty %}{{ ambassador.busFromContact }}, {{ ambassador.busFromPhone }}{% endif %}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
