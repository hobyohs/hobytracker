{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}

{% block body %}

{%- set pct = totalamb > 0 ? ((checkedin / totalamb) * 100)|round : 0 -%}

<div class="ht-page-header">
    <h1>Check In</h1>
    <span class="ht-page-count">{{ checkedin }}/{{ totalamb }}</span>
</div>

<div class="ht-checkin-progress">
    {{ checkedin }} checked in &middot; {{ totalamb - checkedin }} remaining
    <div class="ht-progress-bar"><div class="ht-progress-fill" style="width:{{ pct }}%"></div></div>
</div>

<div class="ht-list-controls">
    <input type="text" id="checkinSearch" class="ht-search-input" placeholder="Search name…" autocomplete="off">
</div>

<div class="ht-card-list" id="checkinList">
    {% for ambassador in ambassadors %}
        <div class="ht-card-row"
             data-name="{{ (ambassador.lastName ~ ' ' ~ ambassador.consolidatedFirstName)|lower }}">
            {{ avatar.render(ambassador) }}
            <div class="ht-card-info">
                <div class="ht-card-name">{{ ambassador.lastName }}, {{ ambassador.consolidatedFirstName }}</div>
            </div>
            <a href="{{ path('app_ambassador_checkin_form', {'id': ambassador.id}) }}"
               class="ht-btn ht-btn-primary" style="white-space:nowrap; flex-shrink:0;">
                Check In
            </a>
        </div>
    {% else %}
        <div class="ht-no-results" style="display:block;">All ambassadors checked in!</div>
    {% endfor %}
    <div class="ht-no-results">No results.</div>
</div>

{# ── Check-in success overlay ────────────────────────────── #}
{% set checkin_name = app.session.get('checkin_success_name') %}
{% if checkin_name %}
    {{ app.session.remove('checkin_success_name') }}
    <div class="ht-checkin-overlay" id="checkinOverlay">
        <div class="ht-checkin-overlay-card">
            <div class="ht-checkin-checkmark">
                <svg viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
                    <circle class="ht-checkin-circle" cx="26" cy="26" r="25" fill="none"/>
                    <path class="ht-checkin-tick" fill="none" d="M14 27 l8 8 l16-16"/>
                </svg>
            </div>
            <div class="ht-checkin-overlay-name">{{ checkin_name }}</div>
            <div class="ht-checkin-overlay-msg">has been checked in!</div>
        </div>
    </div>
    <script>
        (function() {
            var overlay = document.getElementById('checkinOverlay');
            if (!overlay) return;
            // Auto-dismiss after 2.5s, or tap to dismiss immediately
            var timer = setTimeout(dismiss, 2500);
            overlay.addEventListener('click', function() { clearTimeout(timer); dismiss(); });
            function dismiss() {
                overlay.classList.add('ht-checkin-overlay-out');
                overlay.addEventListener('transitionend', function() { overlay.remove(); }, { once: true });
            }
        })();
    </script>
{% endif %}

{% endblock %}
