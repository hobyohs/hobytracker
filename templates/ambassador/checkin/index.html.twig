{% extends 'base.html.twig' %}

{% block body %}

{%- set pct = totalamb > 0 ? ((checkedin / totalamb) * 100)|round : 0 -%}

<div class="ht-page-header">
    <h1>Check In</h1>
    <span class="ht-page-count">{{ checkedin }}/{{ totalamb }}</span>
</div>

<div class="ht-checkin-progress">
    {{ checkedin }} checked in &middot; {{ totalamb - checkedin }} remaining
    <div class="ht-progress-bar"><div class="ht-progress-fill" style="width:{{ pct }}%"></div></div>
</div>

<div class="ht-list-controls">
    <input type="text" id="checkinSearch" class="ht-search-input" placeholder="Search name…" autocomplete="off">
</div>

<div class="ht-card-list" id="checkinList">
    {% for ambassador in ambassadors %}
        <div class="ht-card-row"
             data-name="{{ (ambassador.consolidatedFirstName ~ ' ' ~ ambassador.lastName)|lower }}">
            <div class="ht-card-info">
                <div class="ht-card-name">{{ ambassador.consolidatedFirstName }} {{ ambassador.lastName }}</div>
            </div>
            <a href="{{ path('app_ambassador_checkin_form', {'id': ambassador.id}) }}"
               class="ht-btn ht-btn-primary" style="white-space:nowrap; flex-shrink:0;">
                Check In
            </a>
        </div>
    {% else %}
        <div class="ht-no-results" style="display:block;">All ambassadors checked in!</div>
    {% endfor %}
    <div class="ht-no-results">No results.</div>
</div>

{% endblock %}
