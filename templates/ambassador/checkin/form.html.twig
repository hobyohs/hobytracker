{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}

{% block maintag %}<main class="show ambassador">{% endblock %}

{% block body %}

<a href="{{ path('app_ambassador_checkin') }}" class="ht-script-cancel">
    <i class="fa fa-times" style="font-size:11px;"></i> Cancel
</a>

{# ── Header ─────────────────────────────────────────────── #}
<div class="ht-show-header">
    {{ avatar.render(ambassador, 88) }}
    <div class="ht-show-name">Checking In {{ ambassador.consolidatedFirstName }} {{ ambassador.lastName }}</div>
    <div class="ht-show-subtitle">{{ ambassador.school }}</div>
</div>

<div class="ht-script-body">

    {{ form_start(edit_form) }}

    {# ── 1. Coming/Going schedule ─────────────────────────────── #}
    {% if cg_status %}
        <div class="ht-script-section has-sticker sticker-yellow">
            <div class="ht-script-sticker sticker-yellow"><i class="fa fa-calendar"></i></div>
            <div class="ht-script-content">
                <div class="ht-script-eyebrow">Apply Yellow Sticker</div>
                <h3>{{ ambassador.consolidatedFirstName }} <strong>IS NOT</strong> scheduled to attend the entire seminar. Please confirm this.</h3>
                <div class="ht-cg-schedule">
                    {% for cg in ambassador.comingsAndGoings %}
                        {% if cg.departure is not null %}<div>Leaving <strong>{{ cg.departure|date('D M j \\a\\t g:iA') }}</strong></div>{% endif %}
                        {% if cg.arrival is not null %}<div>Returning <strong>{{ cg.arrival|date('D M j \\a\\t g:iA') }}</strong></div>{% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="ht-override-pair {{ cg_override ? 'override-active' : '' }}" data-override-section="cg" data-ambassador-id="{{ ambassador.id }}">

            <div class="ht-override-default ht-script-section ht-script-section-confirm">
                <button type="button" class="ht-override-btn" data-override-action="toggle-cg">Actually, schedule has changed</button>
                <div class="ht-script-content">
                    <div class="ht-script-eyebrow">Confirm Schedule</div>
                    <h3>{{ ambassador.consolidatedFirstName }} <strong>IS</strong> scheduled to attend the entire seminar.</h3>
                    <p>Please confirm this with {{ ambassador.consolidatedFirstName }} or their family. If their schedule has changed, tap the button above.</p>
                </div>
            </div>

            <div class="ht-override-on ht-script-section has-sticker sticker-yellow">
                <button type="button" class="ht-override-btn ht-override-btn-revert" data-override-action="toggle-cg">Never mind, they'll be here the whole time</button>
                <div class="ht-script-sticker sticker-yellow"><i class="fa fa-calendar"></i></div>
                <div class="ht-script-content">
                    <div class="ht-script-eyebrow">Apply Yellow Sticker</div>
                    <h3>{{ ambassador.consolidatedFirstName }}'s schedule has changed.</h3>
                    <p>Apply a yellow sticker to their nametag and instruct them to visit the Missing Paperwork table to fill in the details.</p>
                </div>
            </div>

        </div>
    {% endif %}

    {# ── 2. Pre-seminar paperwork ─────────────────────────────── #}
    {% if psm_status %}
        <div class="ht-confirm-row">
            <div class="ht-confirm-icon"><i class="fa fa-check"></i></div>
            <div class="ht-confirm-text">
                <div class="ht-confirm-title">Pre-seminar forms</div>
                <div class="ht-confirm-sub">{{ ambassador.consolidatedFirstName }} <strong>DID</strong> fill out all pre-seminar forms.</div>
            </div>
        </div>
    {% else %}
        <div class="ht-script-section has-sticker sticker-yellow">
            <div class="ht-script-sticker sticker-yellow"><i class="fa fa-file-lines"></i></div>
            <div class="ht-script-content">
                <div class="ht-script-eyebrow">Apply Yellow Sticker</div>
                <h3>{{ ambassador.consolidatedFirstName }} <strong>DID NOT</strong> fill out at least one required pre-seminar form.</h3>
                <p>Apply a yellow sticker to their nametag and instruct {{ ambassador.consolidatedFirstName }} to visit the Missing Paperwork table.</p>
            </div>
        </div>
    {% endif %}

    {# ── 3. Key deposit ───────────────────────────────────────── #}
    {% if deposit_status %}
        <div class="ht-confirm-row">
            <div class="ht-confirm-icon"><i class="fa fa-check"></i></div>
            <div class="ht-confirm-text">
                <div class="ht-confirm-title">Key deposit</div>
                <div class="ht-confirm-sub">{{ ambassador.consolidatedFirstName }} <strong>DID</strong> pay their key deposit.</div>
            </div>
        </div>
    {% else %}
        <div class="ht-script-section has-sticker sticker-green">
            <div class="ht-script-sticker sticker-green"><i class="fa fa-key"></i></div>
            <div class="ht-script-content">
                <div class="ht-script-eyebrow">Apply Green Sticker</div>
                <h3>{{ ambassador.consolidatedFirstName }} <strong>DID NOT</strong> pay their key deposit.</h3>
                <p>Apply a green sticker to their nametag and instruct {{ ambassador.consolidatedFirstName }} to visit the HOBY Store to pay their key deposit.</p>
            </div>
        </div>
    {% endif %}

    {# ── 4. Prescription medications ──────────────────────────── #}
    {% if meds_status %}
        <div class="ht-script-section has-sticker sticker-red">
            <div class="ht-script-sticker sticker-red"><i class="fa fa-prescription-bottle-medical"></i></div>
            <div class="ht-script-content">
                <div class="ht-script-eyebrow">Apply Red Sticker</div>
                <h3>{{ ambassador.consolidatedFirstName }} <strong>DOES</strong> have prescription drugs to turn in.</h3>
                <p>Apply a red sticker to their nametag.</p>
            </div>
        </div>
    {% else %}
        <div class="ht-override-pair {{ meds_override ? 'override-active' : '' }}" data-override-section="meds" data-ambassador-id="{{ ambassador.id }}">

            <div class="ht-override-default ht-script-section ht-script-section-confirm">
                <button type="button" class="ht-override-btn" data-override-action="toggle-meds">Actually, they do have prescription drugs</button>
                <div class="ht-script-content">
                    <div class="ht-script-eyebrow">Confirm with Family</div>
                    <h3>{{ ambassador.consolidatedFirstName }} <strong>DOES NOT</strong> have prescription drugs to turn in.</h3>
                    <p>Confirm that this is correct. If {{ ambassador.consolidatedFirstName }} or their family says otherwise, tap the button above.</p>
                </div>
            </div>

            <div class="ht-override-on ht-script-section has-sticker sticker-red">
                <button type="button" class="ht-override-btn ht-override-btn-revert" data-override-action="toggle-meds">Never mind, they don't have any prescription drugs</button>
                <div class="ht-script-sticker sticker-red"><i class="fa fa-prescription-bottle-medical"></i></div>
                <div class="ht-script-content">
                    <div class="ht-script-eyebrow">Apply Red Sticker</div>
                    <h3>{{ ambassador.consolidatedFirstName }} <strong>DOES</strong> have prescription drugs to turn in.</h3>
                    <p>Apply a red sticker to their nametag and send {{ ambassador.consolidatedFirstName }} to the med table.</p>
                </div>
            </div>

        </div>
    {% endif %}

    {# ── 5. Dorm assignment ────────────────────────────────────── #}
    {% if ambassador.dormRoom is not null %}
        <div class="ht-script-info">
            <h3>Dorm Assignment</h3>
            <div class="ht-info-data">{{ ambassador.dorm }} Hall</div>
            <p>Let {{ ambassador.consolidatedFirstName }} know they are assigned to <strong>{{ ambassador.dorm }} Hall</strong>. Tell the family to visit the key table once any stickers are resolved.</p>
        </div>
    {% else %}
        <div class="ht-script-section has-sticker sticker-blue">
            <div class="ht-script-sticker sticker-blue"><i class="fa fa-house"></i></div>
            <div class="ht-script-content">
                <div class="ht-script-eyebrow">No Assignment</div>
                <h3>{{ ambassador.consolidatedFirstName }} does not have a dorm assignment yet.</h3>
                <p>Tell the family to visit the key table once any stickers are resolved.</p>
            </div>
        </div>
    {% endif %}

    <button type="submit" class="ht-script-submit">Check In</button>

    {{ form_end(edit_form) }}

</div>

{% endblock %}
