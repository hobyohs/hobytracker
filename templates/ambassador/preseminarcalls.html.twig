{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}
{% block maintag %}<main class="wide">{% endblock %}
{% block body %}
<div class="ht-page-header"><h1>Pre-Seminar Call Report</h1></div>
<div class="ht-page-subtitle">
    <strong>{{ totalCalled }}</strong> of <strong>{{ totalAmb }}</strong> contacted &middot;
    <strong>{{ totalSuccess }}</strong> successful &middot;
    {{ totalAmb - totalCalled }} not yet called
</div>
<div class="ht-dt-card ht-responsive-table">
    <table class="table" id="calls-table">
        <thead><tr>
            <th class="ht-avatar-col no-export"></th>
            <th>First Name</th><th class="ht-mobile-hide">Last Name</th><th class="ht-mobile-hide">Group</th>
            <th class="ht-mobile-hide">Cell Phone</th><th class="ht-mobile-hide">School</th>
            <th class="ht-mobile-hide">Junior</th><th>Forms</th><th>Disposition</th><th>Notes</th>
            <th class="no-export ht-chevron-col"></th>
        </tr></thead>
        <tbody>
            {% for ambassador in ambassadors %}
                <tr data-href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}">
                    <td class="ht-avatar-col no-export">{{ avatar.render(ambassador, 32) }}</td>
                    <td data-label="First" class="ht-name-td">
                        <span class="ht-name-desktop">{{ ambassador.consolidatedFirstName }}</span>
                        <span class="ht-name-mobile-header">
                            {{ avatar.render(ambassador, 36) }}
                            <span class="ht-card-name">{{ ambassador.consolidatedFirstName }} {{ ambassador.lastName }}</span>
                            {% if ambassador.letterGroup %}<span class="ht-group-badge ht-group-{{ ambassador.letterGroup.color }} ht-card-name-badge">{{ ambassador.letterGroup.letter }}</span>{% endif %}
                        </span>
                    </td>
                    <td data-label="Last" class="ht-mobile-hide">{{ ambassador.lastName }}</td>
                    <td data-label="Group" class="center ht-mobile-hide">{% if ambassador.letterGroup %}<span class="ht-group-badge ht-group-{{ ambassador.letterGroup.color }}">{{ ambassador.letterGroup.letter }}</span>{% else %}<span class="ht-empty">—</span>{% endif %}</td>
                    <td data-label="Cell" class="ht-mobile-hide">{{ ambassador.cellPhone }}</td>
                    <td data-label="School" class="ht-mobile-hide">{{ ambassador.school }}</td>
                    <td data-label="Junior" class="center ht-mobile-hide">
                        {% if ambassador.letterGroup %}
                            {% for junior in ambassador.letterGroup.getJuniorFacilitators %}{{ junior.firstName }} {{ junior.lastName }}<br>{% endfor %}
                        {% else %}<span class="ht-empty">—</span>{% endif %}
                    </td>
                    {% if ambassador.isCheckinPaperwork %}<td data-label="Forms" class="gridblock yay"><span class="fa fa-check"><span class="hidden">TRUE</span></span></td>
                    {% else %}<td data-label="Forms" class="gridblock nay"><span class="fa fa-times"><span class="hidden">FALSE</span></span></td>{% endif %}
                    {% if ambassador.juniorCallDisposition == 'spoke_with_ambassador' %}<td data-label="Status" class="gridblock yay"><span class="fa fa-check"></span>&nbsp;Complete!</td>
                    {% elseif ambassador.juniorCallDisposition == 'left_message' %}<td data-label="Status" class="gridblock pray"><span class="fa fa-voicemail"></span> Left voicemail</td>
                    {% elseif ambassador.juniorCallDisposition == 'spoke_with_family' %}<td data-label="Status" class="gridblock pray"><span class="fa fa-people-group"></span> Spoke with family</td>
                    {% elseif ambassador.juniorCallDisposition == 'wrong_number' %}<td data-label="Status" class="gridblock nay"><span class="fa fa-phone-slash"></span> Wrong number</td>
                    {% elseif ambassador.juniorCallDisposition == 'other' %}<td data-label="Status" class="gridblock okay"><span class="fa fa-circle-question"></span> Other</td>
                    {% else %}<td data-label="Status" class="gridblock oyvey"><span class="fa fa-phone"></span> Not yet called</td>{% endif %}
                    <td data-label="Notes">{{ ambassador.juniorCallNotes }}</td>
                    <td class="no-export ht-chevron-col"><a href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}" class="ht-row-chevron"><i class="fa fa-chevron-right"></i></a></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
