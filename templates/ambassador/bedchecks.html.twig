{% extends 'base.html.twig' %}
{% block maintag %}<main class="show">{% endblock %}

{% block body %}

<div class="ht-page-header">
    <h1>Bed Checks</h1>
</div>

{# ── Night selector ──────────────────────────────────────── #}
<div class="ht-bc-night-bar">
    <span class="ht-bc-night-label">Tonight:</span>
    <div class="ht-bc-night-tabs">
        {% for night in ['Thursday', 'Friday', 'Saturday'] %}
            <a href="?night={{ night }}"
               class="ht-bc-night-tab {{ nightName == night ? 'is-active' : '' }}">
                {{ night }}
            </a>
        {% endfor %}
    </div>
</div>

{# ── Floor cards ─────────────────────────────────────────── #}
{% if floors is empty %}
    <div class="ht-section-card" style="margin: 20px 16px; text-align: center; color: var(--ht-sub);">
        No dorm rooms assigned yet.
    </div>
{% else %}
    <div class="ht-bc-floors">
        {% for floor in floors %}
            {%- set pct = floor.totalAmbs > 0 ? ((floor.confirmedAmbs / floor.totalAmbs) * 100)|round : 0 -%}
            <a href="{{ path('app_ambassador_bedchecks_floor', {'dorm': floor.dorm, 'floor': floor.floor}) }}?night={{ nightName }}"
               class="ht-bc-floor-card {{ floor.confirmedAmbs == floor.totalAmbs and floor.totalAmbs > 0 ? 'is-complete' : '' }}">
                <div class="ht-bc-floor-card-header">
                    <div>
                        <div class="ht-bc-floor-title">{{ floor.dorm }} — Floor {{ floor.floor }}</div>
                        <div class="ht-bc-floor-sub">{{ floor.confirmedRooms }} / {{ floor.totalRooms }} rooms &middot; {{ floor.confirmedAmbs }} / {{ floor.totalAmbs }} ambassadors</div>
                    </div>
                    <i class="fa {{ floor.confirmedAmbs == floor.totalAmbs and floor.totalAmbs > 0 ? 'fa-circle-check' : 'fa-chevron-right' }} ht-bc-floor-icon"></i>
                </div>
                <div class="ht-homepage-progress" style="margin: 10px 0 0;">
                    <div class="ht-homepage-progress-bar" style="width: {{ pct }}%"></div>
                </div>
            </a>
        {% endfor %}
    </div>
{% endif %}

{% endblock %}
