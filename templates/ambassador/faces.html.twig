{% extends 'base.html.twig' %}

{% block body %}
	<h1>Our Ambassadors</h1>

	<div class="container faces">
		<div class="row">
			{% for ambassador in ambassadors %}
				
					<div class="col-sm-6 col-md-4 col-lg-3 mb-4">
						
						<div class="card border-0 shadow">
							<img src="{{ ambassador.photo ?? asset('assets/images/headshot-placeholder.png') }}" class="card-img-top" alt="{{ ambassador.fullName }}">
							<div class="card-body text-center">
								<a href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}" class="stretched-link">
									<h5 class="card-title mb-0">{{ ambassador.fullName }}</h5>
									<div class="card-text">
										{{ ambassador.school }}
										
										{% if not ambassador.letterGroup is null %}
											<br><span class="letter {{ambassador.letterGroup.color}}">Group {{ ambassador.letterGroup.letter }}</span>
										{% endif %}
										
									</div>
									</a>
							</div>
						</div>
					</div>
				
			{% endfor %}
		</div>
	
	</div>

	
{% endblock %}
