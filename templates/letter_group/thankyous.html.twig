{% extends 'base.html.twig' %}

{% block maintag %}<main class="show{% if app.user.letterGroup == group %} bigger{% endif %} user">{% endblock %}

{% block body %}
    <a href="{{ path('app_letter_group_show', { 'letter': group.letter }) }}" class="ht-back-link">
        <i class="fa fa-chevron-left" style="font-size:11px;"></i> Group {{ group.letter }}
    </a>
    <h1>{{ group.printLetterGroup | raw }}</h1>

           
    <h2>Ambassadors</h2>
    <div class="ht-dt-card">
    <table class="table" id="group-thankyou-table">
    	<thead>
    		<tr>
    			<th>First Name</th>
    			<th>Last Name</th>
    			<th>Thank You Type</th>
    			<th>Thank You Assignment</th>
    		</tr>
    	</thead>
        <tbody>
        
        	{% for ambassador in group.ambassadors %}
				<tr>
					<td><a href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}" class="ht-table-name-link">{{ ambassador.consolidatedFirstName }}</a></td>
		            <td>{{ambassador.lastName}}</td>
		            <td>{{ambassador.thankyouType}}</td>
		            <td>{{ambassador.thankyouName}}</td>
				</tr>
	        {% endfor %}
           
        </tbody>
    </table>
    </div>
       
{% endblock %}
