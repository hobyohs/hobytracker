{% extends 'base.html.twig' %}
{% import 'partials/_avatar.html.twig' as avatar %}

{% block maintag %}<main class="show{% if app.user.letterGroup == group %} bigger{% endif %} user">{% endblock %}

{% block body %}

{%- set isMyGroup = (app.user.letterGroup == group) -%}
{%- set groupColor = group.color -%}

{# ── Header ─────────────────────────────────────────────── #}
<div class="ht-group-show-header">
    <div class="ht-group-letter-display ht-group-{{ groupColor }}">{{ group.letter }}</div>
    <div class="ht-show-name">Group {{ group.letter }}</div>
    {% if group.homeBuilding %}
        <div class="ht-show-subtitle">{{ group.homeBuilding }} {{ group.homeRoom }}</div>
    {% endif %}
    {% if group.interviewAssignment %}
        <div style="margin-top: 8px;">
            <span class="ht-room-badge">Interview: {{ group.interviewAssignment }}</span>
        </div>
    {% endif %}
</div>

<div class="ht-show-body">

{# ── Facilitators ────────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Facilitators</div>
    <div class="ht-section-card">
        {% for fac in group.facilitators %}
            <a href="{{ path('app_user_show', { 'id': fac.userId }) }}" class="ht-card-row" style="text-decoration:none; color:inherit; border-bottom: 1px solid var(--ht-border);">
                {{ avatar.render(fac) }}
                <div class="ht-card-info">
                    <div class="ht-card-name">{{ fac.consolidatedFirstName }} {{ fac.lastName }}</div>
                    <div class="ht-card-sub">{{ fac.position }}</div>
                </div>
                <span class="ht-chevron">›</span>
            </a>
        {% else %}
            <div style="padding: 16px; color: var(--ht-sub); font-size: 14px;">No facilitators assigned.</div>
        {% endfor %}
    </div>
</div>

{# ── Ambassadors ─────────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label" style="display:flex; justify-content:space-between; align-items:center;">
        <span>Ambassadors</span>
        <span style="font-weight:400; color: var(--ht-sub);">{{ group.ambassadors|length }}</span>
    </div>
    <div class="ht-card-list" style="margin: 0;">
        {% for ambassador in group.ambassadors %}
            <a href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}"
               class="ht-card-row" style="text-decoration:none; color:inherit;">
                {{ avatar.render(ambassador) }}
                <div class="ht-card-info">
                    <div class="ht-card-name">{{ ambassador.consolidatedFirstName }} {{ ambassador.lastName }}</div>
                    <div class="ht-card-sub">{{ ambassador.school }}</div>
                </div>
                {% if isMyGroup %}
                    <span class="ht-status-pill-group">
                        <span class="ht-status-pill {{ ambassador.isCheckinPaperwork ? 'ht-yes' : 'ht-no' }}"
                              title="Pre-seminar forms {{ ambassador.isCheckinPaperwork ? 'submitted' : 'not yet submitted' }}">
                            <i class="fa fa-file-lines"></i>
                            <span class="ht-pill-label">Forms</span>
                        </span>
                        <span class="ht-status-pill {{ ambassador.isCheckinDeposit ? 'ht-yes' : 'ht-no' }}"
                              title="Key deposit {{ ambassador.isCheckinDeposit ? 'received' : 'not yet received' }}">
                            <i class="fa fa-key"></i>
                            <span class="ht-pill-label">Key</span>
                        </span>
                    </span>
                {% endif %}
                <span class="ht-chevron">›</span>
            </a>
        {% else %}
            <div style="padding: 20px; text-align: center; color: var(--ht-sub); font-size: 14px;">
                No ambassadors assigned.
            </div>
        {% endfor %}
    </div>
</div>

</div>{# end ht-show-body #}

{% endblock %}
