{% extends 'base.html.twig' %}

{% block body %}

<div class="ht-page-header">
    <h1>Homerooms</h1>
</div>

<div class="ht-group-card-grid">
    {% for group in groups %}
        <a href="{{ path('app_letter_group_show', { 'letter': group.letter }) }}" class="ht-group-card">
            <div class="ht-group-card-letter ht-group-{{ group.color }}" style="
                {% if group.color == 'red' %}color: var(--badge-red-text);{% endif %}
                {% if group.color == 'blue' %}color: var(--badge-blue-text);{% endif %}
                {% if group.color == 'green' %}color: var(--badge-green-text);{% endif %}
                {% if group.color == 'yellow' %}color: var(--badge-yellow-text);{% endif %}
                {% if group.color == 'purple' %}color: var(--badge-purple-text);{% endif %}
                {% if group.color == 'teal' %}color: var(--badge-teal-text);{% endif %}
            ">{{ group.letter }}</div>
            <div style="font-size: 13px; font-weight: 500; color: var(--ht-text);">Group {{ group.letter }}</div>
            {% if group.homeBuilding %}
                <div class="ht-group-card-room">{{ group.homeBuilding }} {{ group.homeRoom }}</div>
            {% endif %}
        </a>
    {% endfor %}
</div>

{% endblock %}
