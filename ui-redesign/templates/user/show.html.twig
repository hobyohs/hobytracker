{% extends 'base.html.twig' %}

{% block maintag %}<main class="show user">{% endblock %}

{% block body %}

{%- set initials = user.consolidatedFirstName[0:1]|upper ~ user.lastName[0:1]|upper -%}
{%- set groupColor = user.letterGroup ? user.letterGroup.color : '' -%}

<a href="javascript:history.back()" class="ht-back-link">
    <i class="fa fa-chevron-left" style="font-size:11px;"></i> Staff
</a>

{# ── Header ─────────────────────────────────────────────── #}
<div class="ht-show-header">
    {% if user.photo %}
        <img src="{{ user.photo }}" alt="{{ user.fullName }}" class="ht-show-avatar">
    {% else %}
        <div class="ht-show-avatar-initials">{{ initials }}</div>
    {% endif %}

    <div class="ht-show-name">{{ user.consolidatedFirstName }} {{ user.lastName }}</div>
    <div class="ht-show-subtitle">{{ user.position }}</div>

    <div class="ht-show-badges">
        {% if user.letterGroup %}
            <a href="{{ path('app_letter_group_show', { 'letter': user.letterGroup.letter }) }}"
               class="ht-group-badge ht-group-badge-lg ht-group-{{ groupColor }}"
               style="text-decoration:none;">
               Group {{ user.letterGroup.letter }}
            </a>
        {% endif %}
        {% if user.dormRoom %}
            <span class="ht-room-badge">{{ user.dorm }} {{ user.room }}</span>
        {% endif %}
    </div>
</div>

<div class="ht-show-body">

{# ── Contact ─────────────────────────────────────────────── #}
<div class="ht-section">
    <div class="ht-section-label">Contact</div>
    <div class="ht-section-card">
        {% if user.prefName and user.prefName != user.firstName %}
            <div class="ht-section-row">
                <span class="ht-section-key">Preferred name</span>
                <span class="ht-section-val">{{ user.prefName }}</span>
            </div>
        {% endif %}
        <div class="ht-section-row">
            <span class="ht-section-key">Full name</span>
            <span class="ht-section-val">{{ user.firstName }} {{ user.lastName }}</span>
        </div>
        {% if user.pronouns %}
            <div class="ht-section-row">
                <span class="ht-section-key">Pronouns</span>
                <span class="ht-section-val">{{ user.pronouns }}</span>
            </div>
        {% endif %}
        {% if user.cellPhone %}
            <div class="ht-section-row">
                <span class="ht-section-key">Cell phone</span>
                <span class="ht-section-val">{{ user.cellPhone }}</span>
            </div>
        {% endif %}
        {% if user.email %}
            <div class="ht-section-row">
                <span class="ht-section-key">Email</span>
                <span class="ht-section-val">{{ user.email }}</span>
            </div>
        {% endif %}
        {% if user.shirtSize %}
            <div class="ht-section-row">
                <span class="ht-section-key">Shirt size</span>
                <span class="ht-section-val">{{ user.shirtSize }}</span>
            </div>
        {% endif %}
    </div>
</div>

{# ── Emergency Contact (board only) ─────────────────────── #}
{% if is_granted('ROLE_BOARD') %}

    {% if user.ecFirstName %}
    <div class="ht-section">
        <div class="ht-section-label">Emergency Contact</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Name</span>
                <span class="ht-section-val">{{ user.ecFirstName }} {{ user.ecLastName }}</span>
            </div>
            {% if user.ecRelationship %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Relationship</span>
                    <span class="ht-section-val">{{ user.ecRelationship }}</span>
                </div>
            {% endif %}
            {% if user.ecPhone1 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Phone</span>
                    <span class="ht-section-val">{{ user.ecPhone1 }}</span>
                </div>
            {% endif %}
            {% if user.ecPhone2 %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Alt phone</span>
                    <span class="ht-section-val">{{ user.ecPhone2 }}</span>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

    <div class="ht-section">
        <div class="ht-section-label">Dietary &amp; Health</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Restrictions</span>
                <span class="ht-section-val{% if not user.dietRestrictions %} ht-empty{% endif %}">
                    {{ user.dietRestrictions ?: 'None' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Dietary info</span>
                <span class="ht-section-val{% if not user.dietInfo %} ht-empty{% endif %}">
                    {{ user.dietInfo ?: 'None' }}
                </span>
            </div>
            {% if user.dietSeverity %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Severity</span>
                    <span class="ht-section-val">{{ user.dietSeverity }}</span>
                </div>
            {% endif %}
            <div class="ht-section-row">
                <span class="ht-section-key">Allergies</span>
                <span class="ht-section-val{% if not user.allergies %} ht-empty{% endif %}">
                    {{ user.allergies ?: 'None' }}
                </span>
            </div>
            {% if user.currentConditions %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Current conditions</span>
                    <span class="ht-section-val">{{ user.currentConditions }}</span>
                </div>
            {% endif %}
            {% if user.exerciseLimits %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Exercise limits</span>
                    <span class="ht-section-val">{{ user.exerciseLimits }}</span>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="ht-section">
        <div class="ht-section-label">Requirements</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Paperwork</span>
                <span class="ht-status-dot {{ user.isPaperworkComplete ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isPaperworkComplete ? '✓' : '✗' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">HOBY app</span>
                <span class="ht-status-dot {{ user.isHobyAppComplete ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isHobyAppComplete ? '✓' : '✗' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Hours</span>
                <span class="ht-status-dot {{ user.isHoursComplete ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isHoursComplete ? '✓' : '✗' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Amb. registered</span>
                <span class="ht-status-dot {{ user.isAmbRegistered ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isAmbRegistered ? '✓' : '✗' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Fundraising</span>
                <span class="ht-status-dot {{ user.isFundraisingComplete ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isFundraisingComplete ? '✓' : '✗' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">BG check submitted</span>
                <span class="ht-status-dot {{ user.isBgCheckSubmitted ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isBgCheckSubmitted ? '✓' : '✗' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">BG check complete</span>
                <span class="ht-status-dot {{ user.isBgCheckComplete ? 'ht-yes' : 'ht-no' }}">
                    {{ user.isBgCheckComplete ? '✓' : '✗' }}
                </span>
            </div>
            {% if user.getRequirementNotes %}
                <div class="ht-section-row">
                    <span class="ht-section-key">Notes</span>
                    <span class="ht-section-val">{{ user.getRequirementNotes }}</span>
                </div>
            {% endif %}
        </div>
    </div>

{% endif %}

{# ── Medical (nurse only) ────────────────────────────────── #}
{% if is_granted('ROLE_NURSE') %}
    <div class="ht-section">
        <div class="ht-section-label">Medical</div>
        <div class="ht-section-card">
            <div class="ht-section-row">
                <span class="ht-section-key">Med allergies</span>
                <span class="ht-section-val{% if not user.medAllergies %} ht-empty{% endif %}">
                    {{ user.medAllergies ?: 'None' }}
                </span>
            </div>
            <div class="ht-section-row">
                <span class="ht-section-key">Current Rx</span>
                <span class="ht-section-val{% if not user.currentRx %} ht-empty{% endif %}">
                    {{ user.currentRx ?: 'None' }}
                </span>
            </div>
        </div>
    </div>
{% endif %}

</div>{# end ht-show-body #}

{% endblock %}
