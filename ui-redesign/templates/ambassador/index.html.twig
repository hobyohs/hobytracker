{% extends 'base.html.twig' %}

{% block body %}

{# Build sorted list of letter groups present in this year's data #}
{% set groups_map = {} %}
{% for ambassador in ambassadors %}
    {% if ambassador.letterGroup %}
        {% set groups_map = groups_map|merge({ (ambassador.letterGroup.letter): ambassador.letterGroup }) %}
    {% endif %}
{% endfor %}
{% set sorted_letters = groups_map|keys|sort %}

<div class="ht-page-header">
    <h1>{% if page_title is defined %}{{ page_title }}{% else %}Ambassadors{% endif %}</h1>
    <span class="ht-page-count">{{ ambassadors|length }}</span>
</div>

<div class="ht-list-controls">
    <input type="text" id="ambSearch" class="ht-search-input" placeholder="Search name, school, group…" autocomplete="off" autocorrect="off" spellcheck="false">
    <div class="ht-filter-pills">
        <span class="ht-pill amb-pill active" data-filter="all">All</span>
        {% for letter in sorted_letters %}
            {% set group = groups_map[letter] %}
            <span class="ht-pill amb-pill" data-filter="{{ letter }}">{{ letter }}</span>
        {% endfor %}
    </div>
</div>

<div class="ht-card-list" id="ambList">
    {% for ambassador in ambassadors %}
        {%- set initials = ambassador.consolidatedFirstName[0:1]|upper ~ ambassador.lastName[0:1]|upper -%}
        {%- set groupLetter = ambassador.letterGroup ? ambassador.letterGroup.letter : '' -%}
        {%- set groupColor  = ambassador.letterGroup ? ambassador.letterGroup.color  : '' -%}
        <a href="{{ path('app_ambassador_show', { 'id': ambassador.id }) }}"
           class="ht-card-row"
           data-name="{{ (ambassador.consolidatedFirstName ~ ' ' ~ ambassador.lastName)|lower }}"
           data-school="{{ ambassador.school|lower }}"
           data-group="{{ groupLetter }}">
            <div class="ht-card-avatar">{{ initials }}</div>
            <div class="ht-card-info">
                <div class="ht-card-name">{{ ambassador.consolidatedFirstName }} {{ ambassador.lastName }}</div>
                <div class="ht-card-sub">{{ ambassador.school }}</div>
            </div>
            {% if ambassador.letterGroup %}
                <span class="ht-group-badge ht-group-{{ groupColor }}">{{ groupLetter }}</span>
            {% endif %}
            <span class="ht-chevron">›</span>
        </a>
    {% else %}
        <div class="ht-no-results" style="display:block;">No ambassadors found.</div>
    {% endfor %}
    <div class="ht-no-results">No results match your search.</div>
</div>

{% endblock %}
